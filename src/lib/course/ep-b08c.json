{
  "id": "b08c",
  "nivel": "basico",
  "numero": 8,
  "parte": "5C",
  "titulo": "Na farmácia",
  "subtitulo": "Dor, remédios, receita e itens de viagem",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n01", "pt": "Última parte: a farmácia. Antes, recordando: peça uma sacola. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p01", "promptPt": "Peça uma sacola. Fale agora.", "audioKey": "m-bolsa", "es": "¿Me da una bolsa?", "pt": "Pode me dar uma sacola?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n02", "pt": "Escute na farmácia:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-d6", "es": "Hola, ¿tienen algo para el dolor de cabeza?", "pt": "Oi, vocês têm algo pra dor de cabeça?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "m-d7", "es": "Sí, ¿le duele hace mucho?", "pt": "Sim, dói faz tempo?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n03", "pt": "Pra dizer que está com dor, há uma fórmula que significa 'me dói'. A cabeça:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-cabeza", "es": "Me duele la cabeza.", "pt": "Estou com dor de cabeça." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p02", "promptPt": "Diga 'me dói a cabeça'. Fale agora.", "audioKey": "m-cabeza", "es": "Me duele la cabeza.", "pt": "Estou com dor de cabeça." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n04", "pt": "A barriga / o estômago:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-estomago", "es": "Me duele el estómago.", "pt": "Estou com dor de barriga." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p03", "promptPt": "Diga 'me dói a barriga'. Fale agora.", "audioKey": "m-estomago", "es": "Me duele el estómago.", "pt": "Estou com dor de barriga." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n05", "pt": "Pra pedir um remédio pra dor:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-algodolor", "es": "¿Tienen algo para el dolor?", "pt": "Vocês têm algo pra dor?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p04", "promptPt": "Peça 'algo pra dor'. Fale agora.", "audioKey": "m-algodolor", "es": "¿Tienen algo para el dolor?", "pt": "Vocês têm algo pra dor?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n06", "pt": "Remédios comuns: aspirina e ibuprofeno:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "m-aspirina", "es": "Aspirina.", "pt": "Aspirina." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "m-ibuprofeno", "es": "Ibuprofeno.", "pt": "Ibuprofeno." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep8c-p05", "promptPt": "Peça ibuprofeno. Fale agora.", "audioKey": "m-ibuprofeno", "es": "Ibuprofeno.", "pt": "Ibuprofeno." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n07", "pt": "Pra viagem: protetor solar e repelente:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-protector", "es": "Protector solar.", "pt": "Protetor solar." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-repelente", "es": "Repelente.", "pt": "Repelente." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p06", "promptPt": "Peça protetor solar. Fale agora.", "audioKey": "m-protector", "es": "Protector solar.", "pt": "Protetor solar." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n08", "pt": "Pra saber se precisa de receita:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-receta", "es": "¿Necesito receta?", "pt": "Preciso de receita?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p07", "promptPt": "Pergunte se precisa de receita. Fale agora.", "audioKey": "m-receta", "es": "¿Necesito receta?", "pt": "Preciso de receita?" },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep8c-n09", "pt": "Falso amigo de farmácia, e perigoso! Tem uma palavra que parece 'constipado', mas em espanhol quer dizer 'estou resfriado' — não preso do intestino. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-constipado", "es": "Estoy constipado.", "pt": "Estou resfriado." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p08", "promptPt": "Diga que está resfriado. Fale agora.", "audioKey": "m-constipado", "es": "Estoy constipado.", "pt": "Estou resfriado." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n10", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p09", "promptPt": "Diga 'me dói a cabeça'. Fale agora.", "audioKey": "m-cabeza", "es": "Me duele la cabeza.", "pt": "Estou com dor de cabeça." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep8c-p10", "promptPt": "Pergunte se precisa de receita. Fale agora.", "audioKey": "m-receta", "es": "¿Necesito receta?", "pt": "Preciso de receita?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "m-cabeza", "es": "Me duele la cabeza.", "pt": "Estou com dor de cabeça." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "m-algodolor", "es": "¿Tienen algo para el dolor?", "pt": "Vocês têm algo pra dor?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-r00", "pt": "Pra fechar, uma cena de mercado e farmácia. Você entende tudo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-necesito", "es": "Necesito pan y leche.", "pt": "Preciso de pão e leite." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-cuantokilo", "es": "¿Cuánto cuesta el kilo?", "pt": "Quanto custa o quilo?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-bolsa", "es": "¿Me da una bolsa?", "pt": "Pode me dar uma sacola?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-cabeza", "es": "Me duele la cabeza.", "pt": "Estou com dor de cabeça." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-algodolor", "es": "¿Tienen algo para el dolor?", "pt": "Vocês têm algo pra dor?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n11", "pt": "Gramática em foco: pra dizer que dói, usa-se uma fórmula que significa 'me dói' seguida da parte do corpo. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-cabeza", "es": "Me duele la cabeza.", "pt": "Me dói a cabeça." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-estomago", "es": "Me duele el estómago.", "pt": "Me dói o estômago." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep8c-n12", "pt": "Essa fórmula avisa qualquer dor. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep8c-rend", "pt": "Parabéns! Você se vira no mercado e na farmácia. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Dor, remédios e o falso amigo constipado",
    "secoes": [
      {
        "titulo": "me duele (doer)",
        "corpo": "'Me duele' + parte do corpo diz onde dói. No plural, 'me duelen' (ex.: me duelen los pies).",
        "exemplos": [
          { "es": "Me duele la cabeza.", "pt": "Me dói a cabeça." },
          { "es": "Me duele el estómago.", "pt": "Me dói o estômago." }
        ]
      },
      {
        "titulo": "Na farmácia",
        "corpo": "'¿Tienen algo para…?' pede um remédio; 'receta' é receita; protector solar e repelente são essenciais de viagem."
      },
      {
        "titulo": "Falso amigo: constipado",
        "corpo": "'Estoy constipado' = estou RESFRIADO (gripado), não preso do intestino. Prisão de ventre é 'estreñimiento'."
      }
    ]
  }
}
