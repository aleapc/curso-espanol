{
  "id": "i06a",
  "nivel": "intermediario",
  "numero": 15,
  "parte": "A",
  "titulo": "Socializar — Gostos",
  "subtitulo": "Falar do que você gosta",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n01", "pt": "Intermediário, episódio 6: socializar. Parte 1: falar de gostos. Fale em voz alta quando eu pedir." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n02", "pt": "Recordando: diga 'vou viajar'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso1-p01", "promptPt": "Diga 'vou viajar'. Fale agora.", "audioKey": "fu-voyviajar", "es": "Voy a viajar.", "pt": "Vou viajar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n03", "pt": "Escute uma conversa sobre gostos:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-d1", "es": "¿Qué te gusta hacer?", "pt": "Do que você gosta de fazer?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-d2", "es": "Me encanta viajar.", "pt": "Eu adoro viajar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n04", "pt": "Pra dizer que gosta de algo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-megusta", "es": "Me gusta el fútbol.", "pt": "Eu gosto de futebol." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso1-p02", "promptPt": "Diga 'eu gosto de futebol'. Fale agora.", "audioKey": "so-megusta", "es": "Me gusta el fútbol.", "pt": "Eu gosto de futebol." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n05", "pt": "Pra dizer que adora, com mais força:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-encanta", "es": "Me encanta viajar.", "pt": "Eu adoro viajar." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso1-p03", "promptPt": "Diga 'eu adoro viajar'. Fale agora.", "audioKey": "so-encanta", "es": "Me encanta viajar.", "pt": "Eu adoro viajar." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n06", "pt": "Pra dizer que NÃO gosta de algo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-nogusta", "es": "No me gusta el frío.", "pt": "Não gosto do frio." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso1-p04", "promptPt": "Diga 'não gosto do frio'. Fale agora.", "audioKey": "so-nogusta", "es": "No me gusta el frío.", "pt": "Não gosto do frio." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n07", "pt": "Pra perguntar do que a pessoa gosta:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-quetegusta", "es": "¿Qué te gusta hacer?", "pt": "Do que você gosta de fazer?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso1-p05", "promptPt": "Pergunte 'do que você gosta de fazer?'. Fale agora.", "audioKey": "so-quetegusta", "es": "¿Qué te gusta hacer?", "pt": "Do que você gosta de fazer?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n08", "pt": "Pra dizer que algo te interessa:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-interesa", "es": "Me interesa la historia.", "pt": "Me interessa história." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso1-p06", "promptPt": "Diga 'me interessa história'. Fale agora.", "audioKey": "so-interesa", "es": "Me interesa la historia.", "pt": "Me interessa história." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n09", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso1-p07", "promptPt": "Diga 'eu gosto de futebol'. Fale agora.", "audioKey": "so-megusta", "es": "Me gusta el fútbol.", "pt": "Eu gosto de futebol." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso1-p08", "promptPt": "Diga 'eu adoro viajar'. Fale agora.", "audioKey": "so-encanta", "es": "Me encanta viajar.", "pt": "Eu adoro viajar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "so-megusta", "es": "Me gusta el fútbol.", "pt": "Eu gosto de futebol." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "so-encanta", "es": "Me encanta viajar.", "pt": "Eu adoro viajar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n10", "pt": "Gramática em foco: tem o verbo de gostar e o de adorar (esse é mais forte). Quando o que você gosta está no plural, o verbo também vai pro plural. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-megusta", "es": "Me gusta el fútbol.", "pt": "Eu gosto de futebol." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-encanta", "es": "Me encanta viajar.", "pt": "Eu adoro viajar." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso1-n11", "pt": "Os verbos de gostar e adorar, que viram plural quando o objeto é plural. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "iso1-rend", "pt": "Muito bem! Você fala dos seus gostos. Na próxima: convidar e aceitar. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
  "aprofundar": {
    "titulo": "Gustar e encantar",
    "secoes": [
      {
        "titulo": "Como funciona",
        "corpo": "Singular: me gusta el café. Plural: me gustan los cafés. 'Me encanta' é mais forte (adoro). Pra negar: no me gusta.",
        "exemplos": [
          { "es": "Me gustan las empanadas.", "pt": "Eu gosto de empanadas." },
          { "es": "No me gusta madrugar.", "pt": "Não gosto de acordar cedo." }
        ]
      }
    ]
  }
}
