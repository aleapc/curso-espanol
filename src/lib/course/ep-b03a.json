{
  "id": "b03a",
  "nivel": "basico",
  "numero": 3,
  "parte": "A",
  "titulo": "Na rua — Direções",
  "subtitulo": "Pedir e entender como chegar",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n01", "pt": "Vamos nos virar na rua! Parte 1: pedir e entender direções. Fale em voz alta quando eu pedir." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n02", "pt": "Recordando do jeito de perguntar onde fica: 'onde está o banheiro?'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep3a-p01", "promptPt": "Pergunte onde fica o banheiro, '¿dónde está el baño?'. Fale agora.", "audioKey": "tr-donde", "es": "¿Dónde está el baño?", "pt": "Onde fica o banheiro?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n03", "pt": "Escute alguém pedindo direção:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "tr-d1", "es": "Disculpe, ¿cómo llego al centro?", "pt": "Com licença, como chego ao centro?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "tr-d2", "es": "Seguí derecho y doblá a la derecha.", "pt": "Siga reto e vire à direita." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n04", "pt": "Pra perguntar como chegar a um lugar:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "tr-llego", "es": "¿Cómo llego al centro?", "pt": "Como chego ao centro?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep3a-p02", "promptPt": "Pergunte 'como chego ao centro?'. Fale agora.", "audioKey": "tr-llego", "es": "¿Cómo llego al centro?", "pt": "Como chego ao centro?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n05", "pt": "As direções. À direita:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "tr-derecha", "es": "A la derecha.", "pt": "À direita." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep3a-p03", "promptPt": "Diga 'à direita', a la derecha. Fale agora.", "audioKey": "tr-derecha", "es": "A la derecha.", "pt": "À direita." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n06", "pt": "À esquerda:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "tr-izquierda", "es": "A la izquierda.", "pt": "À esquerda." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep3a-p04", "promptPt": "Diga 'à esquerda', a la izquierda. Fale agora.", "audioKey": "tr-izquierda", "es": "A la izquierda.", "pt": "À esquerda." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep3a-n07", "pt": "Falso amigo importante! 'Derecho' não é 'direito' — é RETO, em frente. À direita é 'a la derecha'. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "tr-derecho", "es": "Seguí derecho.", "pt": "Siga reto." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep3a-p05", "promptPt": "Diga 'siga reto', seguí derecho. Fale agora.", "audioKey": "tr-derecho", "es": "Seguí derecho.", "pt": "Siga reto." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n08", "pt": "Perto e longe:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "tr-cerca", "es": "Está cerca.", "pt": "Está perto." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "tr-lejos", "es": "Está lejos.", "pt": "Está longe." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep3a-p06", "promptPt": "Diga 'está perto', está cerca. Fale agora.", "audioKey": "tr-cerca", "es": "Está cerca.", "pt": "Está perto." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n09", "pt": "A esquina:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "tr-esquina", "es": "En la esquina.", "pt": "Na esquina." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep3a-p07", "promptPt": "Diga 'na esquina', en la esquina. Fale agora.", "audioKey": "tr-esquina", "es": "En la esquina.", "pt": "Na esquina." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n10", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep3a-p08", "promptPt": "Pergunte 'como chego ao centro?'. Fale agora.", "audioKey": "tr-llego", "es": "¿Cómo llego al centro?", "pt": "Como chego ao centro?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep3a-p09", "promptPt": "Diga 'à direita'. Fale agora.", "audioKey": "tr-derecha", "es": "A la derecha.", "pt": "À direita." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "tr-llego", "es": "¿Cómo llego al centro?", "pt": "Como chego ao centro?" },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "tr-derecho", "es": "Seguí derecho.", "pt": "Siga reto." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n11", "pt": "Gramática em foco: não confunda! 'A la derecha' é à direita; 'derecho' (sem 'a la') é reto. E pra localizar usa-se 'estar': está cerca, está lejos. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "tr-derecha", "es": "A la derecha.", "pt": "À direita." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "tr-derecho", "es": "Derecho.", "pt": "Reto." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep3a-n12", "pt": "'A la derecha' (direita) vs 'derecho' (reto) — a pegadinha clássica. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep3a-rend", "pt": "Ótimo! Você pede e entende direção. Na próxima: os transportes. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
  "aprofundar": {
    "titulo": "Direções (e o falso amigo derecho)",
    "secoes": [
      {
        "titulo": "Esquerda, direita, reto",
        "corpo": "a la izquierda (à esquerda), a la derecha (à direita), derecho / todo recto (reto, em frente).",
        "exemplos": [
          { "es": "Seguí derecho y doblá a la derecha.", "pt": "Siga reto e vire à direita." }
        ]
      },
      {
        "titulo": "Localizar (estar)",
        "corpo": "está cerca (perto), está lejos (longe), en la esquina (na esquina), a dos cuadras (a dois quarteirões).",
        "exemplos": [
          { "es": "¿Dónde está el baño?", "pt": "Onde fica o banheiro?" }
        ]
      }
    ]
  }
}
