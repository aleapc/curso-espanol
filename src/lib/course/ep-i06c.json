{
  "id": "i06c",
  "nivel": "intermediario",
  "numero": 15,
  "parte": "C",
  "titulo": "Socializar — Dar opinião",
  "subtitulo": "Opinar, concordar e reagir numa conversa",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n01", "pt": "Última parte: dar opinião e reagir. Antes, recordando: convide 'quer ir ao cinema?'. Responda." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso3-p01", "promptPt": "Convide: 'quer ir ao cinema?'. Fale agora.", "audioKey": "so-queres", "es": "¿Querés ir al cine?", "pt": "Quer ir ao cinema?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n02", "pt": "Escute uma conversa com opiniões:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-d5", "es": "¿Qué te parece la idea?", "pt": "O que você acha da ideia?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-d6", "es": "Creo que está buena. Estoy de acuerdo.", "pt": "Acho que é boa. Concordo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n03", "pt": "Pra pedir a opinião de alguém:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-queteparece", "es": "¿Qué te parece?", "pt": "O que você acha?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso3-p02", "promptPt": "Pergunte 'o que você acha?'. Fale agora.", "audioKey": "so-queteparece", "es": "¿Qué te parece?", "pt": "O que você acha?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n04", "pt": "Pra dar a sua opinião, começando com 'acho que…':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-creo", "es": "Creo que sí.", "pt": "Acho que sim." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso3-p03", "promptPt": "Diga 'acho que sim'. Fale agora.", "audioKey": "so-creo", "es": "Creo que sí.", "pt": "Acho que sim." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n05", "pt": "Pra concordar:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-deacuerdo", "es": "Estoy de acuerdo.", "pt": "Concordo." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso3-p04", "promptPt": "Diga 'concordo'. Fale agora.", "audioKey": "so-deacuerdo", "es": "Estoy de acuerdo.", "pt": "Concordo." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n06", "pt": "Pra discordar com educação:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-nodeacuerdo", "es": "No estoy de acuerdo.", "pt": "Não concordo." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso3-p05", "promptPt": "Diga 'não concordo'. Fale agora.", "audioKey": "so-nodeacuerdo", "es": "No estoy de acuerdo.", "pt": "Não concordo." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n07", "pt": "E pra reagir com surpresa, tipo 'sério?':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-enserio", "es": "¿En serio?", "pt": "Sério?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso3-p06", "promptPt": "Reaja com surpresa, tipo 'sério?'. Fale agora.", "audioKey": "so-enserio", "es": "¿En serio?", "pt": "Sério?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n08", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso3-p07", "promptPt": "Diga 'acho que sim'. Fale agora.", "audioKey": "so-creo", "es": "Creo que sí.", "pt": "Acho que sim." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso3-p08", "promptPt": "Diga 'concordo'. Fale agora.", "audioKey": "so-deacuerdo", "es": "Estoy de acuerdo.", "pt": "Concordo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "so-creo", "es": "Creo que sí.", "pt": "Acho que sim." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "so-deacuerdo", "es": "Estoy de acuerdo.", "pt": "Concordo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-r00", "pt": "Pra fechar, uma conversa social completa. Você entende tudo:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-queteparece", "es": "¿Qué te parece?", "pt": "O que você acha?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-creo", "es": "Creo que sí.", "pt": "Acho que sim." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-queres", "es": "¿Querés ir al cine?", "pt": "Quer ir ao cinema?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-encantaria", "es": "¡Me encantaría!", "pt": "Eu adoraria!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-deacuerdo", "es": "Estoy de acuerdo.", "pt": "Concordo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n09", "pt": "Gramática em foco: pra opinar, comece com 'acho que…' mais a sua frase; depois tem a expressão de concordar e a de discordar. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-creo", "es": "Creo que sí.", "pt": "Acho que sim." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-deacuerdo", "es": "Estoy de acuerdo.", "pt": "Concordo." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso3-n10", "pt": "As fórmulas de opinar e de concordar. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "iso3-rend", "pt": "Parabéns! Você conversa, opina e socializa. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Opinar e concordar",
    "secoes": [
      {
        "titulo": "Dar opinião",
        "corpo": "¿Qué te parece? (o que acha?), Creo que… / Para mí… (acho que…/pra mim…), Me parece que…",
        "exemplos": [
          { "es": "Creo que tenés razón.", "pt": "Acho que você tem razão." }
        ]
      },
      {
        "titulo": "Concordar / discordar",
        "corpo": "Estoy de acuerdo (concordo), No estoy de acuerdo (discordo), Depende. Reações: ¿En serio? ¡Qué bueno! ¡Qué pena!"
      }
    ]
  }
}
