{
  "id": "i03a",
  "nivel": "intermediario",
  "numero": 12,
  "parte": "A",
  "titulo": "Planes y futuro — O que vou fazer",
  "subtitulo": "O futuro fácil: ir a + verbo",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n01", "pt": "Intermediário, episódio 3: planos e futuro. Parte 1: o que você VAI fazer. Fale em voz alta quando eu pedir." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n02", "pt": "Recordando: diga 'antes eu morava em São Paulo'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu1-p01", "promptPt": "Diga 'antes eu morava em São Paulo'. Fale agora.", "audioKey": "ru-vivia", "es": "Antes vivía en São Paulo.", "pt": "Antes eu morava em São Paulo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n03", "pt": "Escute planos:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fu-d1", "es": "¿Qué vas a hacer mañana?", "pt": "O que você vai fazer amanhã?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-d2", "es": "Voy a visitar a un amigo.", "pt": "Vou visitar um amigo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n04", "pt": "O futuro fácil: o verbo 'ir' mais 'a' mais outro verbo. Pra dizer 'vou viajar':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-voyviajar", "es": "Voy a viajar.", "pt": "Vou viajar." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu1-p02", "promptPt": "Diga 'vou viajar'. Fale agora.", "audioKey": "fu-voyviajar", "es": "Voy a viajar.", "pt": "Vou viajar." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n05", "pt": "'Vou comer fora':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fu-voycomer", "es": "Voy a comer afuera.", "pt": "Vou comer fora." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ifu1-p03", "promptPt": "Diga 'vou comer fora'. Fale agora.", "audioKey": "fu-voycomer", "es": "Voy a comer afuera.", "pt": "Vou comer fora." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n06", "pt": "Pra perguntar 'o que você vai fazer?':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-vasahacer", "es": "¿Qué vas a hacer?", "pt": "O que você vai fazer?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu1-p04", "promptPt": "Pergunte 'o que você vai fazer?'. Fale agora.", "audioKey": "fu-vasahacer", "es": "¿Qué vas a hacer?", "pt": "O que você vai fazer?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n07", "pt": "No 'nós', a mesma ideia. Pra dizer 'vamos passear':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fu-vamospasear", "es": "Vamos a pasear.", "pt": "Vamos passear." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ifu1-p05", "promptPt": "Diga 'vamos passear'. Fale agora.", "audioKey": "fu-vamospasear", "es": "Vamos a pasear.", "pt": "Vamos passear." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n08", "pt": "Pra dizer o que você quer fazer, use o verbo 'querer' mais outro verbo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-quierover", "es": "Quiero ver la ciudad.", "pt": "Quero ver a cidade." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu1-p06", "promptPt": "Diga 'quero ver a cidade'. Fale agora.", "audioKey": "fu-quierover", "es": "Quiero ver la ciudad.", "pt": "Quero ver a cidade." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n09", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu1-p07", "promptPt": "Diga 'vou viajar'. Fale agora.", "audioKey": "fu-voyviajar", "es": "Voy a viajar.", "pt": "Vou viajar." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu1-p08", "promptPt": "Pergunte 'o que você vai fazer?'. Fale agora.", "audioKey": "fu-vasahacer", "es": "¿Qué vas a hacer?", "pt": "O que você vai fazer?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "fu-voyviajar", "es": "Voy a viajar.", "pt": "Vou viajar." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "fu-vasahacer", "es": "¿Qué vas a hacer?", "pt": "O que você vai fazer?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n10", "pt": "Gramática em foco: o futuro mais usado é o verbo 'ir' mais 'a' mais o infinitivo. Igualzinho ao 'vou fazer' do português. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-voyviajar", "es": "Voy a viajar.", "pt": "Vou viajar." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fu-vamospasear", "es": "Vamos a pasear.", "pt": "Vamos passear." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu1-n11", "pt": "É o verbo 'ir' conjugado mais 'a' mais o verbo. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ifu1-rend", "pt": "Muito bem! Você fala dos seus planos. Na próxima: dizer quando — amanhã, semana que vem. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
  "aprofundar": {
    "titulo": "Futuro com ir a + infinitivo",
    "secoes": [
      {
        "titulo": "A fórmula",
        "corpo": "voy a, vas a (vos), va a, vamos a, van a + o verbo no infinitivo. É o futuro do dia a dia, idêntico ao 'vou + verbo' do português.",
        "exemplos": [
          { "es": "Voy a viajar la semana que viene.", "pt": "Vou viajar na semana que vem." },
          { "es": "¿Qué vas a hacer hoy?", "pt": "O que você vai fazer hoje?" }
        ]
      },
      {
        "titulo": "Querer + infinitivo",
        "corpo": "Pra intenção/vontade: quiero + verbo (quiero ver, quiero ir).",
        "exemplos": [
          { "es": "Quiero ver la ciudad.", "pt": "Quero ver a cidade." }
        ]
      }
    ]
  }
}
