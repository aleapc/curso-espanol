  "titulo": "Planes y futuro — Quando",
  "subtitulo": "Amanhã, hoje à noite, semana que vem",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n01", "pt": "Parte 2: dizer QUANDO. Antes, recordando: diga 'vou viajar'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu2-p01", "promptPt": "Diga 'vou viajar'. Fale agora.", "audioKey": "fu-voyviajar", "es": "Voy a viajar.", "pt": "Vou viajar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n02", "pt": "Escute alguns planos com tempo:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fu-d3", "es": "Mañana voy a la playa.", "pt": "Amanhã vou à praia." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-d4", "es": "La semana que viene viajo a Colonia.", "pt": "Semana que vem viajo a Colônia." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n03", "pt": "Pra dizer 'amanhã':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "t-manana", "es": "Mañana.", "pt": "Amanhã." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ifu2-p02", "promptPt": "Diga 'amanhã'. Fale agora.", "audioKey": "t-manana", "es": "Mañana.", "pt": "Amanhã." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n04", "pt": "Pra dizer 'hoje à noite':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-estanoche", "es": "Esta noche.", "pt": "Hoje à noite." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu2-p03", "promptPt": "Diga 'hoje à noite'. Fale agora.", "audioKey": "fu-estanoche", "es": "Esta noche.", "pt": "Hoje à noite." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n05", "pt": "Pra dizer 'mais tarde':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-mastarde", "es": "Más tarde.", "pt": "Mais tarde." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu2-p04", "promptPt": "Diga 'mais tarde'. Fale agora.", "audioKey": "fu-mastarde", "es": "Más tarde.", "pt": "Mais tarde." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n06", "pt": "Pra dizer 'a semana que vem':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fu-semana", "es": "La semana que viene.", "pt": "A semana que vem." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ifu2-p05", "promptPt": "Diga 'a semana que vem'. Fale agora.", "audioKey": "fu-semana", "es": "La semana que viene.", "pt": "A semana que vem." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n07", "pt": "Pra dizer 'o mês que vem':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-mes", "es": "El mes que viene.", "pt": "O mês que vem." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ifu2-p06", "promptPt": "Diga 'o mês que vem'. Fale agora.", "audioKey": "fu-mes", "es": "El mes que viene.", "pt": "O mês que vem." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n08", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ifu2-p07", "promptPt": "Diga 'amanhã'. Fale agora.", "audioKey": "t-manana", "es": "Mañana.", "pt": "Amanhã." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ifu2-p08", "promptPt": "Diga 'a semana que vem'. Fale agora.", "audioKey": "fu-semana", "es": "La semana que viene.", "pt": "A semana que vem." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "fu-semana", "es": "La semana que viene.", "pt": "A semana que vem." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "fu-estanoche", "es": "Esta noche.", "pt": "Hoje à noite." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n09", "pt": "Gramática em foco: pra dizer 'que vem' — a semana que vem, o mês que vem, o ano que vem — há uma expressão fixa que encaixa direto no plano. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fu-semana", "es": "La semana que viene.", "pt": "A semana que vem." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-mes", "es": "El mes que viene.", "pt": "O mês que vem." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ifu2-n10", "pt": "É a expressão que equivale ao nosso '... que vem'. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ifu2-rend", "pt": "Muito bem! Você situa os planos no tempo. Na última parte: combinar encontros. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
