{
  "id": "b09c",
  "nivel": "basico",
  "numero": 9,
  "parte": "6C",
  "titulo": "Falsos amigos — Tempo e estados",
  "subtitulo": "Largo, rato, todavía, constipado",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-n01", "pt": "Última parte dos falsos amigos: tempo e estados. Fale em voz alta quando eu pedir." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep9c-n02", "pt": "'Largo' é COMPRIDO, não largura. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-largo", "es": "Me queda largo.", "pt": "Ficou comprido (em mim)." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep9c-p01", "promptPt": "Diga que ficou comprido, 'me queda largo'. Fale agora.", "audioKey": "c-largo", "es": "Me queda largo.", "pt": "Ficou comprido." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep9c-n03", "pt": "'Rato' não é o bicho — é um INSTANTE, um momentinho. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep9c-p02", "promptPt": "Diga 'espera um instante', esperá un rato. Fale agora.", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep9c-n04", "pt": "'Todavía' não é 'todavia/contudo' — é AINDA. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep9c-p03", "promptPt": "Diga 'ainda não chegou', todavía no llegó. Fale agora.", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep9c-n05", "pt": "Da farmácia: 'constipado' é RESFRIADO, não preso do intestino. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-constipado", "es": "Estoy constipado.", "pt": "Estou resfriado." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep9c-p04", "promptPt": "Diga que está resfriado, 'estoy constipado'. Fale agora.", "audioKey": "m-constipado", "es": "Estoy constipado.", "pt": "Estou resfriado." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-n06", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep9c-p05", "promptPt": "Diga 'espera um instante'. Fale agora.", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep9c-p06", "promptPt": "Diga 'ainda não chegou'. Fale agora.", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-r00", "pt": "Pra fechar, ouça os falsos amigos em frases. Agora você não cai em nenhum:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-exq2", "es": "La comida está exquisita.", "pt": "A comida está deliciosa." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r-vaso", "es": "Un vaso de agua, por favor.", "pt": "Um copo de água, por favor." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fa-embarazada", "es": "Ella está embarazada.", "pt": "Ela está grávida." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-n07", "pt": "Gramática em foco, o resumo: parecido NÃO é igual. Exquisito, vaso, jamón, salsa, embarazada, oficina, cena, largo, rato, todavía, constipado. Onze armadilhas que agora são suas amigas." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep9c-rend", "pt": "Parabéns! Você fechou os falsos amigos — e o módulo Básico inteiro! Que jornada. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Falsos amigos de tempo e estado",
    "secoes": [
      {
        "titulo": "A lista",
        "corpo": "Os que mudam o sentido de uma frase inteira:",
        "exemplos": [
          { "es": "largo", "pt": "comprido (largura = ancho)" },
          { "es": "rato", "pt": "um instante (o bicho = ratón)" },
          { "es": "todavía", "pt": "ainda (não 'todavia/contudo')" },
          { "es": "constipado", "pt": "resfriado (não prisão de ventre)" }
        ]
      }
    ]
  }
}
