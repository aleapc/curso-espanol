{
  "id": "b09c",
  "nivel": "basico",
  "numero": 9,
  "parte": "6C",
  "titulo": "Armadilhas do Portunhol — Tempo e estados",
  "subtitulo": "Largo, rato, todavía, constipado",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-n01", "pt": "Última parte da revisão das armadilhas: tempo e estados. Fale em voz alta quando eu pedir." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep9c-n02", "pt": "A palavra que parece 'largo' quer dizer COMPRIDO, não largura. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-largo", "es": "Me queda largo.", "pt": "Ficou comprido (em mim)." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep9c-p01", "promptPt": "Diga que ficou comprido. Fale agora.", "audioKey": "c-largo", "es": "Me queda largo.", "pt": "Ficou comprido." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep9c-n03", "pt": "A palavra que parece 'rato' não é o bicho — é um INSTANTE, um momentinho. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep9c-p02", "promptPt": "Diga 'espera um instante'. Fale agora.", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep9c-n04", "pt": "Tem uma palavra que parece 'todavia/contudo' — mas quer dizer AINDA. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep9c-p03", "promptPt": "Diga 'ainda não chegou'. Fale agora.", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep9c-n05", "pt": "Da farmácia: a palavra que parece 'constipado' quer dizer RESFRIADO, não preso do intestino. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-constipado", "es": "Estoy constipado.", "pt": "Estou resfriado." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep9c-p04", "promptPt": "Diga que está resfriado. Fale agora.", "audioKey": "m-constipado", "es": "Estoy constipado.", "pt": "Estou resfriado." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-n06", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep9c-p05", "promptPt": "Diga 'espera um instante'. Fale agora.", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep9c-p06", "promptPt": "Diga 'ainda não chegou'. Fale agora.", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-r00", "pt": "Pra fechar, ouça as armadilhas em frases. Agora você não cai em nenhuma:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-exq2", "es": "La comida está exquisita.", "pt": "A comida está deliciosa." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r-vaso", "es": "Un vaso de agua, por favor.", "pt": "Um copo de água, por favor." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fa-embarazada", "es": "Ella está embarazada.", "pt": "Ela está grávida." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fa-rato", "es": "Esperá un rato.", "pt": "Espera um instante." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "fa-todavia", "es": "Todavía no llegó.", "pt": "Ainda não chegou." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep9c-n07", "pt": "Gramática em foco, o resumo: parecido NÃO é igual. Foram onze armadilhas nestes três episódios — comida, objetos, pessoas, lugares, tempo e estados. Agora elas são suas amigas." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep9c-rend", "pt": "Parabéns! Você fechou as armadilhas do portunhol — e o módulo Básico inteiro! Que jornada. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
