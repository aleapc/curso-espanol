{
  "id": "b06b",
  "nivel": "basico",
  "numero": 6,
  "parte": "3B",
  "titulo": "De compras — Tamanho e provar",
  "subtitulo": "Talle, provar e como a roupa fica em você",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n01", "pt": "Parte 2: tamanho e provar a roupa. Antes, recordando: pergunte se têm em outra cor. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6b-p01", "promptPt": "Pergunte se têm em outra cor. Fale agora.", "audioKey": "c-otrocolor", "es": "¿Lo tienen en otro color?", "pt": "Vocês têm em outra cor?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n02", "pt": "Escute o casal provando roupa:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-d4", "es": "¿Qué talle busca?", "pt": "Que tamanho o senhor procura?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-d5", "es": "Talle mediano. ¿Puedo probármelo?", "pt": "Tamanho médio. Posso provar?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-d6", "es": "Sí, el probador está al fondo.", "pt": "Sim, o provador é lá no fundo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n03", "pt": "Tamanho, no Rio da Prata, tem um nome próprio. Pra perguntar:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-talle", "es": "¿Qué talle?", "pt": "Que tamanho?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep6b-p02", "promptPt": "Pergunte 'que tamanho?'. Fale agora.", "audioKey": "c-talle", "es": "¿Qué talle?", "pt": "Que tamanho?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n04", "pt": "Os tamanhos: pequeno, médio, grande:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-chico", "es": "Talle chico.", "pt": "Tamanho P (pequeno)." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-mediano", "es": "Talle mediano.", "pt": "Tamanho M (médio)." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-grande", "es": "Talle grande.", "pt": "Tamanho G (grande)." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6b-p03", "promptPt": "Diga 'tamanho médio'. Fale agora.", "audioKey": "c-mediano", "es": "Talle mediano.", "pt": "Tamanho médio." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n05", "pt": "Pra pedir pra provar:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-probar", "es": "¿Puedo probármelo?", "pt": "Posso provar?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6b-p04", "promptPt": "Pergunte 'posso provar?'. Fale agora.", "audioKey": "c-probar", "es": "¿Puedo probármelo?", "pt": "Posso provar?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n06", "pt": "Pra achar o provador:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-probador", "es": "¿Dónde está el probador?", "pt": "Onde fica o provador?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6b-p05", "promptPt": "Pergunte onde fica o provador. Fale agora.", "audioKey": "c-probador", "es": "¿Dónde está el probador?", "pt": "Onde fica o provador?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n07", "pt": "Pra dizer como ficou — 'ficou bom em mim':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-quedabien", "es": "Me queda bien.", "pt": "Ficou bom (em mim)." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep6b-p06", "promptPt": "Diga 'ficou bom em mim'. Fale agora.", "audioKey": "c-quedabien", "es": "Me queda bien.", "pt": "Ficou bom (em mim)." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n08", "pt": "Ficou grande, ou ficou pequeno:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-quedagrande", "es": "Me queda grande.", "pt": "Ficou grande (em mim)." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-quedachico", "es": "Me queda chico.", "pt": "Ficou pequeno (em mim)." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6b-p07", "promptPt": "Diga 'ficou grande em mim'. Fale agora.", "audioKey": "c-quedagrande", "es": "Me queda grande.", "pt": "Ficou grande." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "ep6b-n09", "pt": "Falso amigo de roupa: tem uma palavra igual a 'largo' do português, mas em espanhol não é largura — é comprido. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-largo", "es": "Me queda largo.", "pt": "Ficou comprido (em mim)." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep6b-p08", "promptPt": "Diga que ficou comprido. Fale agora.", "audioKey": "c-largo", "es": "Me queda largo.", "pt": "Ficou comprido." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n10", "pt": "Pra pedir um número maior:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-masgrande", "es": "¿Tienen un talle más grande?", "pt": "Vocês têm um tamanho maior?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6b-p09", "promptPt": "Peça um tamanho maior. Fale agora.", "audioKey": "c-masgrande", "es": "¿Tienen un talle más grande?", "pt": "Vocês têm um tamanho maior?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n11", "pt": "Gostou? 'Vou levar':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-mellevo", "es": "Me lo llevo.", "pt": "Vou levar." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6b-p10", "promptPt": "Diga 'vou levar'. Fale agora.", "audioKey": "c-mellevo", "es": "Me lo llevo.", "pt": "Vou levar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n12", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6b-p11", "promptPt": "Pergunte 'posso provar?'. Fale agora.", "audioKey": "c-probar", "es": "¿Puedo probármelo?", "pt": "Posso provar?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep6b-p12", "promptPt": "Diga 'ficou bom em mim'. Fale agora.", "audioKey": "c-quedabien", "es": "Me queda bien.", "pt": "Ficou bom." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "c-probar", "es": "¿Puedo probármelo?", "pt": "Posso provar?" },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "c-mellevo", "es": "Me lo llevo.", "pt": "Vou levar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n13", "pt": "Gramática em foco: tem um verbo que diz como a roupa fica em você — fica bem, fica grande, fica pequena. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-quedabien", "es": "Me queda bien.", "pt": "Fica bem (em mim)." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-quedagrande", "es": "Me queda grande.", "pt": "Fica grande (em mim)." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6b-n14", "pt": "Esse verbo diz como fica … em mim. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep6b-rend", "pt": "Muito bem! Você prova e escolhe o tamanho. Na última parte: preço, pagar e trocar. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
  "aprofundar": {
    "titulo": "Tamanho, provar e o verbo quedar",
    "secoes": [
      {
        "titulo": "Talle (tamanho)",
        "corpo": "No Rio da Prata, tamanho é 'talle'. Os básicos: chico (P), mediano (M), grande (G).",
        "exemplos": [
          { "es": "¿Qué talle?", "pt": "Que tamanho?" },
          { "es": "¿Tienen un talle más grande?", "pt": "Têm um tamanho maior?" }
        ]
      },
      {
        "titulo": "quedar (como fica em você)",
        "corpo": "'Me queda…' diz como a peça fica em você: bien, grande, chico, largo.",
        "exemplos": [
          { "es": "Me queda bien.", "pt": "Fica bem em mim." },
          { "es": "Me queda chico.", "pt": "Ficou pequeno em mim." }
        ]
      },
      {
        "titulo": "Falso amigo: largo",
        "corpo": "'Largo' em espanhol é COMPRIDO, não largura. 'Me queda largo' = ficou comprido. Largura é 'ancho'."
      }
    ]
  }
}
