{
  "id": "a02b",
  "nivel": "avancado",
  "numero": 18,
  "parte": "B",
  "titulo": "Condicional — Hipóteses",
  "subtitulo": "Si tuviera tiempo, viajaría",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n01", "pt": "Parte 2: hipóteses, o 'se eu pudesse, eu faria'. Antes, recordando: peça 'você poderia me ajudar?'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "aco2-p01", "promptPt": "Peça 'você poderia me ajudar?', ¿podrías ayudarme?. Fale agora.", "audioKey": "co-podrias", "es": "¿Podrías ayudarme?", "pt": "Você poderia me ajudar?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n02", "pt": "Escute uma hipótese:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "co-d3", "es": "Si tuviera tiempo, viajaría más.", "pt": "Se eu tivesse tempo, viajaria mais." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "co-d4", "es": "Yo también. ¿Adónde irías?", "pt": "Eu também. Aonde você iria?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n03", "pt": "A hipótese clássica — 'se eu tivesse tempo, viajaria':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "co-situviera", "es": "Si tuviera tiempo, viajaría.", "pt": "Se eu tivesse tempo, viajaria." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "aco2-p02", "promptPt": "Diga 'se eu tivesse tempo, viajaria', si tuviera tiempo, viajaría. Fale agora.", "audioKey": "co-situviera", "es": "Si tuviera tiempo, viajaría.", "pt": "Se eu tivesse tempo, viajaria." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n04", "pt": "Com 'poder' — 'se eu pudesse, iria':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "co-sipudiera", "es": "Si pudiera, iría.", "pt": "Se eu pudesse, iria." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "aco2-p03", "promptPt": "Diga 'se eu pudesse, iria', si pudiera, iría. Fale agora.", "audioKey": "co-sipudiera", "es": "Si pudiera, iría.", "pt": "Se eu pudesse, iria." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n05", "pt": "Pra perguntar o que a pessoa faria — '¿qué harías?':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "co-queharias", "es": "¿Qué harías en mi lugar?", "pt": "O que você faria no meu lugar?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "aco2-p04", "promptPt": "Pergunte 'o que você faria no meu lugar?', ¿qué harías en mi lugar?. Fale agora.", "audioKey": "co-queharias", "es": "¿Qué harías en mi lugar?", "pt": "O que você faria no meu lugar?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n06", "pt": "E pra responder — 'eu iria…':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "co-yoiria", "es": "Yo iría sin pensarlo.", "pt": "Eu iria sem pensar." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "aco2-p05", "promptPt": "Diga 'eu iria sem pensar', yo iría sin pensarlo. Fale agora.", "audioKey": "co-yoiria", "es": "Yo iría sin pensarlo.", "pt": "Eu iria sem pensar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n07", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "aco2-p06", "promptPt": "Diga 'se eu tivesse tempo, viajaria'. Fale agora.", "audioKey": "co-situviera", "es": "Si tuviera tiempo, viajaría.", "pt": "Se eu tivesse tempo, viajaria." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "aco2-p07", "promptPt": "Pergunte 'o que você faria no meu lugar?'. Fale agora.", "audioKey": "co-queharias", "es": "¿Qué harías en mi lugar?", "pt": "O que você faria no meu lugar?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "co-situviera", "es": "Si tuviera tiempo, viajaría.", "pt": "Se eu tivesse tempo, viajaria." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "co-sipudiera", "es": "Si pudiera, iría.", "pt": "Se eu pudesse, iria." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n08", "pt": "Gramática em foco: a hipótese tem duas partes — 'si' + imperfeito do subjuntivo (tuviera, pudiera) e o condicional (viajaría, iría). Igual ao 'se eu tivesse…, eu faria' do português. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "co-situviera", "es": "Si tuviera tiempo, viajaría.", "pt": "Se eu tivesse tempo, viajaria." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "co-sipudiera", "es": "Si pudiera, iría.", "pt": "Se eu pudesse, iria." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "aco2-n09", "pt": "'Si' + tivesse/pudesse + faria/iria. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "aco2-rend", "pt": "Muito bem! Você levanta hipóteses como nativo. Na última parte: dar conselhos. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Hipóteses (si + subjuntivo + condicional)",
    "secoes": [
      {
        "titulo": "A estrutura",
        "corpo": "Si + imperfeito do subjuntivo (tuviera, pudiera, fuera) + condicional (viajaría, iría, sería). Bate com o português 'se eu tivesse…, eu faria'.",
        "exemplos": [
          { "es": "Si tuviera plata, me compraría una casa.", "pt": "Se eu tivesse dinheiro, compraria uma casa." },
          { "es": "Si fuera vos, lo haría.", "pt": "Se eu fosse você, faria isso." }
        ]
      }
    ]
  }
}
