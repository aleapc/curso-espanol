  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n01", "pt": "Intermediário, episódio 7, o último! Cultura rioplatense. Parte 1: o mate. Fale em voz alta quando eu pedir." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n02", "pt": "Recordando: diga 'concordo'. Responda." },
