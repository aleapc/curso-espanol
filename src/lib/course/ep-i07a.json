    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n03", "pt": "Escute uma cena de mate — você VAI ouvir muito isso:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-d1", "es": "¿Querés un mate?", "pt": "Quer um mate?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-d2", "es": "¡Dale, gracias!", "pt": "Quero, obrigado!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n04", "pt": "A bebida em si — 'el mate':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-mate", "es": "El mate.", "pt": "O mate." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "icu1-p02", "promptPt": "Diga 'o mate', el mate. Fale agora.", "audioKey": "cu-mate", "es": "El mate.", "pt": "O mate." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n05", "pt": "Quando te oferecerem — '¿querés un mate?':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-queresmate", "es": "¿Querés un mate?", "pt": "Quer um mate?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "icu1-p03", "promptPt": "Ofereça: 'quer um mate?', ¿querés un mate?. Fale agora.", "audioKey": "cu-queresmate", "es": "¿Querés un mate?", "pt": "Quer um mate?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n06", "pt": "A erva — 'la yerba':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-yerba", "es": "La yerba.", "pt": "A erva (do mate)." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "icu1-p04", "promptPt": "Diga 'a erva', la yerba. Fale agora.", "audioKey": "cu-yerba", "es": "La yerba.", "pt": "A erva." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n07", "pt": "A garrafa térmica — 'el termo':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-termo", "es": "El termo.", "pt": "A garrafa térmica." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "icu1-p05", "promptPt": "Diga 'a garrafa térmica', el termo. Fale agora.", "audioKey": "cu-termo", "es": "El termo.", "pt": "A garrafa térmica." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n08", "pt": "Preparar e servir o mate é 'cebar':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-cebar", "es": "Voy a cebar un mate.", "pt": "Vou preparar um mate." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "icu1-p06", "promptPt": "Diga 'vou preparar um mate', voy a cebar un mate. Fale agora.", "audioKey": "cu-cebar", "es": "Voy a cebar un mate.", "pt": "Vou preparar um mate." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n09", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "icu1-p07", "promptPt": "Ofereça 'quer um mate?'. Fale agora.", "audioKey": "cu-queresmate", "es": "¿Querés un mate?", "pt": "Quer um mate?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "icu1-p08", "promptPt": "Diga 'o mate'. Fale agora.", "audioKey": "cu-mate", "es": "El mate.", "pt": "O mate." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "cu-queresmate", "es": "¿Querés un mate?", "pt": "Quer um mate?" },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "cu-cebar", "es": "Voy a cebar un mate.", "pt": "Vou preparar um mate." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n10", "pt": "Cultura em foco: o mate é compartilhado — uma só bomba (canudo) passa de mão em mão na roda. Aceitar um mate é aceitar a amizade. Não mexa na bomba e devolva o mate a quem serve. Escute de novo o convite:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-queresmate", "es": "¿Querés un mate?", "pt": "Quer um mate?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu1-n11", "pt": "Mate é convivência. Mais sobre o ritual em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "icu1-rend", "pt": "Muito bem! Você entra na roda de mate. Na próxima: fútbol, asado e vida social. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
