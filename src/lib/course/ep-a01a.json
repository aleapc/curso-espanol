{
  "id": "a01a",
  "nivel": "avancado",
  "numero": 17,
  "parte": "A",
  "titulo": "El subjuntivo — Desejos e votos",
  "subtitulo": "Que tengas un buen día: o subjuntivo que você já vai usar",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n01", "pt": "Bem-vindo ao Avançado! Aqui a gente lapida. Episódio 1: o subjuntivo — parece bicho de sete cabeças, mas começa por frases que você vai usar muito. Parte 1: desejos e votos. Fale em voz alta quando eu pedir." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n02", "pt": "Recordando do Intermediário: diga 'acho que sim'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "asu1-p01", "promptPt": "Diga 'acho que sim'. Fale agora.", "audioKey": "so-creo", "es": "Creo que sí.", "pt": "Acho que sim." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n03", "pt": "Escute uma despedida cheia de votos:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "su-d1", "es": "¡Que tengas un buen viaje!", "pt": "Tenha uma boa viagem!" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "su-d2", "es": "¡Gracias, igualmente!", "pt": "Obrigado, igualmente!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n04", "pt": "O voto mais comum:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "su-buendia", "es": "Que tengas un buen día.", "pt": "Tenha um bom dia." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "asu1-p02", "promptPt": "Deseje 'tenha um bom dia'. Fale agora.", "audioKey": "su-buendia", "es": "Que tengas un buen día.", "pt": "Tenha um bom dia." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n05", "pt": "Pra desejar boa viagem:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "su-buenviaje", "es": "Que tengas un buen viaje.", "pt": "Tenha uma boa viagem." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "asu1-p03", "promptPt": "Deseje 'boa viagem'. Fale agora.", "audioKey": "su-buenviaje", "es": "Que tengas un buen viaje.", "pt": "Tenha uma boa viagem." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n06", "pt": "Pra quem está doente:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "su-mejores", "es": "Que te mejores.", "pt": "Melhoras. / Fique bom." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "asu1-p04", "promptPt": "Deseje melhoras. Fale agora.", "audioKey": "su-mejores", "es": "Que te mejores.", "pt": "Melhoras." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n07", "pt": "Pra dizer 'tomara':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "su-ojala", "es": "Ojalá que sí.", "pt": "Tomara que sim." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "asu1-p05", "promptPt": "Diga 'tomara que sim'. Fale agora.", "audioKey": "su-ojala", "es": "Ojalá que sí.", "pt": "Tomara que sim." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n08", "pt": "Pra expressar esperança:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "su-espero", "es": "Espero que te guste.", "pt": "Espero que você goste." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "asu1-p06", "promptPt": "Diga 'espero que você goste'. Fale agora.", "audioKey": "su-espero", "es": "Espero que te guste.", "pt": "Espero que você goste." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n09", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "asu1-p07", "promptPt": "Deseje 'tenha um bom dia'. Fale agora.", "audioKey": "su-buendia", "es": "Que tengas un buen día.", "pt": "Tenha um bom dia." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "asu1-p08", "promptPt": "Deseje 'boa viagem'. Fale agora.", "audioKey": "su-buenviaje", "es": "Que tengas un buen viaje.", "pt": "Tenha uma boa viagem." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "su-buendia", "es": "Que tengas un buen día.", "pt": "Tenha um bom dia." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "su-ojala", "es": "Ojalá que sí.", "pt": "Tomara que sim." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n10", "pt": "Gramática em foco: depois de um desejo ou esperança, o verbo entra no subjuntivo — a terminação muda. É o modo do que a gente deseja, não do que é fato. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "su-buendia", "es": "Que tengas un buen día.", "pt": "Tenha um bom dia. (tengas)" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "su-espero", "es": "Espero que te guste.", "pt": "Espero que goste. (guste)" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "asu1-n11", "pt": "Subjuntivo = o modo do desejo. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "asu1-rend", "pt": "Muito bem! Você já solta os votos do dia a dia. Na próxima: pedir que alguém faça algo. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "O subjuntivo dos desejos",
    "secoes": [
      {
        "titulo": "Votos prontos (decore inteiros)",
        "corpo": "Funcionam como blocos: Que tengas un buen día / buen viaje / buen finde; Que te mejores; Que les vaya bien; Que descanses.",
        "exemplos": [
          { "es": "Que tengas un buen día.", "pt": "Tenha um bom dia." },
          { "es": "Que te mejores.", "pt": "Melhoras." }
        ]
      },
      {
        "titulo": "Ojalá / espero que",
        "corpo": "'Ojalá' (tomara) e 'espero que' sempre pedem subjuntivo: ojalá venga, espero que llueva, espero que te guste.",
        "exemplos": [
          { "es": "Ojalá que sí.", "pt": "Tomara que sim." }
        ]
      },
      {
        "titulo": "A ideia",
        "corpo": "O subjuntivo é o modo do desejo, da dúvida e da emoção — não dos fatos. Depois de 'que', o verbo muda a terminação: -ar → -e (hable), -er/-ir → -a (coma, viva)."
      }
    ]
  }
}
