      {
        "titulo": "Na viagem",
        "corpo": "un boleto (passagem), '¿a qué hora sale?' (a que horas sai?), 'pare aquí' (pare aqui), la parada (ponto).",
        "exemplos": [
          { "es": "Un boleto al centro.", "pt": "Uma passagem ao centro." }
        ]
      },
      {
        "titulo": "Se perdeu? Peça ajuda",
        "corpo": "'Estoy perdido/a' (estou perdido/a), '¿me puede ayudar?' (pode me ajudar?). O imperativo dá instruções: pare, seguí, doblá.",
        "exemplos": [
          { "es": "Estoy perdido, ¿me puede ayudar?", "pt": "Estou perdido, pode me ajudar?" }
        ]
      }
    ]
  }
}
