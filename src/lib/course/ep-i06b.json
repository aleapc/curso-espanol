{
  "id": "i06b",
  "nivel": "intermediario",
  "numero": 15,
  "parte": "B",
  "titulo": "Socializar — Convidar",
  "subtitulo": "Fazer um convite, aceitar e recusar com jeito",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n01", "pt": "Parte 2: convidar e responder a convites. Antes, recordando: diga 'eu adoro viajar'. Responda." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso2-p01", "promptPt": "Diga 'eu adoro viajar', me encanta viajar. Fale agora.", "audioKey": "so-encanta", "es": "Me encanta viajar.", "pt": "Eu adoro viajar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n02", "pt": "Escute um convite:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-d3", "es": "¿Querés ir al cine?", "pt": "Quer ir ao cinema?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-d4", "es": "¡Dale, me encantaría!", "pt": "Beleza, eu adoraria!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n03", "pt": "Pra convidar, do jeito vos — '¿querés ir a…?':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-queres", "es": "¿Querés ir al cine?", "pt": "Quer ir ao cinema?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso2-p02", "promptPt": "Convide: 'quer ir ao cinema?', ¿querés ir al cine?. Fale agora.", "audioKey": "so-queres", "es": "¿Querés ir al cine?", "pt": "Quer ir ao cinema?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n04", "pt": "Outro jeito — 'vamos a tomar algo?' (vamos beber algo?):" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-vamostomar", "es": "¿Vamos a tomar algo?", "pt": "Vamos beber alguma coisa?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso2-p03", "promptPt": "Convide: 'vamos beber algo?', ¿vamos a tomar algo?. Fale agora.", "audioKey": "so-vamostomar", "es": "¿Vamos a tomar algo?", "pt": "Vamos beber alguma coisa?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n05", "pt": "Pra aceitar com entusiasmo — 'me encantaría':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-encantaria", "es": "¡Me encantaría!", "pt": "Eu adoraria!" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso2-p04", "promptPt": "Aceite: 'eu adoraria!', me encantaría. Fale agora.", "audioKey": "so-encantaria", "es": "¡Me encantaría!", "pt": "Eu adoraria!" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n06", "pt": "Pra recusar com educação — 'hoy no puedo, otro día':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-nopuedo", "es": "Hoy no puedo, ¿otro día?", "pt": "Hoje não posso, outro dia?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "iso2-p05", "promptPt": "Recuse com jeito: 'hoje não posso, outro dia?'. Fale agora.", "audioKey": "so-nopuedo", "es": "Hoy no puedo, ¿otro día?", "pt": "Hoje não posso, outro dia?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n07", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso2-p06", "promptPt": "Convide: 'quer ir ao cinema?'. Fale agora.", "audioKey": "so-queres", "es": "¿Querés ir al cine?", "pt": "Quer ir ao cinema?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "iso2-p07", "promptPt": "Aceite: 'eu adoraria!'. Fale agora.", "audioKey": "so-encantaria", "es": "¡Me encantaría!", "pt": "Eu adoraria!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "so-queres", "es": "¿Querés ir al cine?", "pt": "Quer ir ao cinema?" },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "so-encantaria", "es": "¡Me encantaría!", "pt": "Eu adoraria!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n08", "pt": "Gramática em foco: pra convidar no vos, '¿querés…?' (quer…?) + verbo, ou '¿vamos a…?' (vamos…?). Pra aceitar, 'me encantaría / dale'; pra recusar, suavize com 'hoy no puedo, ¿otro día?'. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "so-queres", "es": "¿Querés ir al cine?", "pt": "Quer ir ao cinema?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "so-nopuedo", "es": "Hoy no puedo, ¿otro día?", "pt": "Hoje não posso, outro dia?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "iso2-n09", "pt": "Convidar, aceitar, recusar com jeito. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "iso2-rend", "pt": "Muito bem! Você convida e responde convites. Na última parte: dar opinião. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
  "aprofundar": {
    "titulo": "Convidar, aceitar e recusar",
    "secoes": [
      {
        "titulo": "Convidar (vos)",
        "corpo": "¿Querés + infinitivo? (querés ir, querés tomar); ¿Vamos a + infinitivo? (vamos a comer). ¿Te gustaría + infinitivo? é mais formal.",
        "exemplos": [
          { "es": "¿Querés ir a tomar algo?", "pt": "Quer ir beber alguma coisa?" }
        ]
      },
      {
        "titulo": "Responder",
        "corpo": "Aceitar: ¡Dale! / ¡Me encantaría! / Con gusto. Recusar com jeito: Hoy no puedo, ¿otro día? / Me encantaría, pero no puedo."
      }
    ]
  }
}
