{
  "id": "b01a",
  "nivel": "basico",
  "numero": 1,
  "parte": "1A",
  "titulo": "Cumprimentar e responder",
  "subtitulo": "Saudações por horário, como vai, e as respostas",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n01", "pt": "Olá! Eu sou a Bia. Esta é a parte 1 do Episódio 1: cumprimentar e responder. Aqui você não só ouve, você fala. Sempre que aparecer 'fale agora', responda em voz alta." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n02", "pt": "Escute esta troca rápida só pra pegar a sonoridade:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "b01-d1", "es": "¡Hola! Buenos días.", "pt": "Oi! Bom dia." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "b01-d2", "es": "¡Buenos días! ¿Cómo estás?", "pt": "Bom dia! Como você está?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "b01-d3", "es": "Muy bien, gracias. ¿Y vos?", "pt": "Muito bem, obrigada. E você?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n03", "pt": "Vamos treinar. 'Bom dia':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-bd", "es": "Buenos días.", "pt": "Bom dia." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep1a-p01", "promptPt": "Diga 'bom dia'. Fale agora.", "audioKey": "es-bd", "es": "Buenos días.", "pt": "Bom dia." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n04", "pt": "'Boa tarde':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-bt", "es": "Buenas tardes.", "pt": "Boa tarde." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep1a-p02", "promptPt": "Diga 'boa tarde'. Fale agora.", "audioKey": "es-bt", "es": "Buenas tardes.", "pt": "Boa tarde." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n05", "pt": "'Boa noite', que serve de saudação à noite e também de despedida:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-bn", "es": "Buenas noches.", "pt": "Boa noite." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep1a-p03", "promptPt": "Diga 'boa noite'. Fale agora.", "audioKey": "es-bn", "es": "Buenas noches.", "pt": "Boa noite." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n06", "pt": "Para perguntar como a pessoa está, o jeito neutro:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "es-ce", "es": "¿Cómo estás?", "pt": "Como você está?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep1a-p04", "promptPt": "Pergunte 'como você está?'. Fale agora.", "audioKey": "es-ce", "es": "¿Cómo estás?", "pt": "Como você está?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n07", "pt": "Bem rioplatense, com o verbo 'andar' no lugar de 'estar':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "es-comoandas", "es": "¿Cómo andás?", "pt": "Como vai?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep1a-p05", "promptPt": "Pergunte 'como vai?' do jeito rioplatense, com 'andar'. Fale agora.", "audioKey": "es-comoandas", "es": "¿Cómo andás?", "pt": "Como vai?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n08", "pt": "E o mais curtinho de todos:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "es-quetal", "es": "¿Qué tal?", "pt": "E aí?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep1a-p06", "promptPt": "Diga o cumprimento curto, 'e aí?'. Fale agora.", "audioKey": "es-quetal", "es": "¿Qué tal?", "pt": "E aí?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n09", "pt": "Agora as respostas. O coringa é 'tudo bem, e você?':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-todobien", "es": "Todo bien, ¿y vos?", "pt": "Tudo bem, e você?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep1a-p07", "promptPt": "Responda 'tudo bem, e você?'. Fale agora.", "audioKey": "es-todobien", "es": "Todo bien, ¿y vos?", "pt": "Tudo bem, e você?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n10", "pt": "'Muito bem, obrigado':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-mb", "es": "Muy bien, gracias.", "pt": "Muito bem, obrigado." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep1a-p08", "promptPt": "Responda 'muito bem, obrigado'. Fale agora.", "audioKey": "es-mb", "es": "Muy bien, gracias.", "pt": "Muito bem, obrigado." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n11", "pt": "E 'mais ou menos', pros dias mais ou menos:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-masomenos", "es": "Más o menos.", "pt": "Mais ou menos." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep1a-p09", "promptPt": "Responda 'mais ou menos'. Fale agora.", "audioKey": "es-masomenos", "es": "Más o menos.", "pt": "Mais ou menos." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n12", "pt": "Vamos recordar o que você treinou. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep1a-p10", "promptPt": "Como se diz 'bom dia'? Fale agora.", "audioKey": "es-bd", "es": "Buenos días.", "pt": "Bom dia." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep1a-p11", "promptPt": "Pergunte 'como vai?' do jeito rioplatense. Fale agora.", "audioKey": "es-comoandas", "es": "¿Cómo andás?", "pt": "Como vai?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep1a-p12", "promptPt": "Responda 'tudo bem, e você?'. Fale agora.", "audioKey": "es-todobien", "es": "Todo bien, ¿y vos?", "pt": "Tudo bem, e você?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-s00", "pt": "Agora treine o sotaque: repita junto, ao mesmo tempo, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "es-sh1", "es": "¡Hola! ¿Cómo estás?", "pt": "Oi! Como você está?" },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "es-todobien", "es": "Todo bien, ¿y vos?", "pt": "Tudo bem, e você?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n13", "pt": "Pra fechar, a gramática em foco. Existem dois jeitos de tratar alguém: o informal, com amigos e gente da sua idade; e o formal, com quem você não conhece ou num lugar de serviço. Ouça a mesma pergunta nos dois jeitos:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "es-comoandas", "es": "¿Cómo andás?", "pt": "Como vai? (informal)" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "es-comoestaud", "es": "¿Cómo está usted?", "pt": "Como o(a) senhor(a) está? (formal)" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep1a-n14", "pt": "A primeira é informal; a segunda, formal. Na dúvida, comece formal — nunca ofende. Se quiser entender a fundo, abra 'Para ir além' no fim da tela." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep1a-rend", "pt": "Muito bem! Parte 1 fechada. Na parte 2 você aprende a ser educado e a se virar quando não entender. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-hasta", "es": "Hasta luego.", "pt": "Até logo." }
  ],
  "aprofundar": {
    "titulo": "Vos, tú e usted — o tratamento",
    "secoes": [
      {
        "titulo": "O que é o voseo",
        "corpo": "No Uruguai e na Argentina, no lugar do 'tú' usa-se 'vos'. Não é gíria nem 'errado' — é o jeito padrão de falar informalmente. O verbo muda: tira-se o '-r' do infinitivo, acentua-se a última vogal e acrescenta-se '-s'.",
        "exemplos": [
          { "es": "vos sos", "pt": "você é" },
          { "es": "vos tenés", "pt": "você tem" },
          { "es": "¿cómo andás?", "pt": "como vai?" }
        ]
      },
      {
        "titulo": "Quando usar usted (formal)",
        "corpo": "Use 'usted' com quem você não conhece, com pessoas mais velhas e em situações de serviço (recepção, garçom, médico). O verbo vai na 3ª pessoa.",
        "exemplos": [
          { "es": "¿Cómo está usted?", "pt": "Como o(a) senhor(a) está?" }
        ]
      },
      {
        "titulo": "Regra prática",
        "corpo": "Comece formal (usted) com estranhos e serviço; com amigos e gente da sua idade, vá de 'vos'. Muitas vezes a própria pessoa te puxa pro informal — aí você acompanha."
      }
    ]
  }
}
