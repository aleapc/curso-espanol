{
  "id": "b02a",
  "nivel": "basico",
  "numero": 2,
  "parte": "A",
  "titulo": "Números — De 0 a 20",
  "subtitulo": "Contar do zero ao vinte",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n01", "pt": "Hora dos números! Parte 1: de zero a vinte. Eles aparecem em preço, hora, tudo. Fale em voz alta quando eu pedir." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n02", "pt": "Escute de um a cinco:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-1a5", "es": "Uno, dos, tres, cuatro, cinco.", "pt": "Um, dois, três, quatro, cinco." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n03", "pt": "De seis a dez:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-6a10", "es": "Seis, siete, ocho, nueve, diez.", "pt": "Seis, sete, oito, nove, dez." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n04", "pt": "Agora treine alguns. 'Três':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-tres", "es": "Tres.", "pt": "Três." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p01", "promptPt": "Diga 'três', tres. Fale agora.", "audioKey": "n-tres", "es": "Tres.", "pt": "Três." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n05", "pt": "'Cinco':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-cinco", "es": "Cinco.", "pt": "Cinco." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p02", "promptPt": "Diga 'cinco'. Fale agora.", "audioKey": "n-cinco", "es": "Cinco.", "pt": "Cinco." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n06", "pt": "'Oito':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-ocho", "es": "Ocho.", "pt": "Oito." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p03", "promptPt": "Diga 'oito', ocho. Fale agora.", "audioKey": "n-ocho", "es": "Ocho.", "pt": "Oito." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n07", "pt": "'Dez':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-diez", "es": "Diez.", "pt": "Dez." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p04", "promptPt": "Diga 'dez', diez. Fale agora.", "audioKey": "n-diez", "es": "Diez.", "pt": "Dez." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n08", "pt": "Agora de onze a quinze:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-11a15", "es": "Once, doce, trece, catorce, quince.", "pt": "Onze, doze, treze, quatorze, quinze." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n09", "pt": "Treine 'quinze':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-quince", "es": "Quince.", "pt": "Quinze." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p05", "promptPt": "Diga 'quinze', quince. Fale agora.", "audioKey": "n-quince", "es": "Quince.", "pt": "Quinze." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n10", "pt": "De dezesseis a vinte:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-16a20", "es": "Dieciséis, diecisiete, dieciocho, diecinueve, veinte.", "pt": "Dezesseis, dezessete, dezoito, dezenove, vinte." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n11", "pt": "Treine 'vinte':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-veinte", "es": "Veinte.", "pt": "Vinte." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p06", "promptPt": "Diga 'vinte', veinte. Fale agora.", "audioKey": "n-veinte", "es": "Veinte.", "pt": "Vinte." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n12", "pt": "E o zero, 'cero':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-cero", "es": "Cero.", "pt": "Zero." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p07", "promptPt": "Diga 'zero', cero. Fale agora.", "audioKey": "n-cero", "es": "Cero.", "pt": "Zero." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n13", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p08", "promptPt": "Diga 'cinco'. Fale agora.", "audioKey": "n-cinco", "es": "Cinco.", "pt": "Cinco." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p09", "promptPt": "Diga 'dez'. Fale agora.", "audioKey": "n-diez", "es": "Diez.", "pt": "Dez." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2a-p10", "promptPt": "Diga 'vinte'. Fale agora.", "audioKey": "n-veinte", "es": "Veinte.", "pt": "Vinte." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-s00", "pt": "Shadowing: conte junto comigo, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "n-1a5", "es": "Uno, dos, tres, cuatro, cinco.", "pt": "Um a cinco." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "n-6a10", "es": "Seis, siete, ocho, nueve, diez.", "pt": "Seis a dez." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n14", "pt": "Gramática em foco: de dezesseis a dezenove, junta 'dieci' mais o número: dieciséis, diecisiete. De vinte e um em diante, 'veinti' mais o número: veintiuno, veintidós. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-16a20", "es": "Dieciséis, diecisiete, dieciocho, diecinueve.", "pt": "Dezesseis, dezessete, dezoito, dezenove." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2a-n15", "pt": "'Dieci' e 'veinti' montam a faixa dos adolescentes. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep2a-rend", "pt": "Ótimo! Você conta até vinte. Na próxima: dezenas, centenas e preços. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
  "aprofundar": {
    "titulo": "Números 0–20",
    "secoes": [
      {
        "titulo": "A lista",
        "corpo": "cero, uno, dos, tres, cuatro, cinco, seis, siete, ocho, nueve, diez, once, doce, trece, catorce, quince.",
        "exemplos": [
          { "es": "dieciséis, diecisiete, dieciocho", "pt": "16, 17, 18 (dieci + número)" },
          { "es": "diecinueve, veinte", "pt": "19, 20" }
        ]
      }
    ]
  }
}
