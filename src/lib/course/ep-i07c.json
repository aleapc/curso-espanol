{
  "id": "i07c",
  "nivel": "intermediario",
  "numero": 16,
  "parte": "C",
  "titulo": "Cultura — Gírias rioplatenses",
  "subtitulo": "Che, dale, bárbaro: soar local",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n01", "pt": "Última parte do Intermediário: as gírias que fazem você soar local. Antes, recordando: diga 'vamos fazer um churrasco'. Responda." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "icu3-p01", "promptPt": "Diga 'vamos fazer um churrasco', hacemos un asado. Fale agora.", "audioKey": "cu-asado", "es": "Hacemos un asado.", "pt": "Vamos fazer um churrasco." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n02", "pt": "Escute uma conversa bem rioplatense:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-d5", "es": "Che, ¿qué onda? ¿Vamos?", "pt": "Ô, e aí? Vamos?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-d6", "es": "¡Dale, bárbaro!", "pt": "Beleza, ótimo!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n03", "pt": "'Che' é o 'ô, ei' pra chamar alguém — supermarcante por lá:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-che", "es": "Che, ¿cómo andás?", "pt": "Ô, como vai?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "icu3-p02", "promptPt": "Chame alguém: 'che, ¿cómo andás?'. Fale agora.", "audioKey": "cu-che", "es": "Che, ¿cómo andás?", "pt": "Ô, como vai?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n04", "pt": "'¿Qué onda?' é 'e aí?', 'como é que tá?':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-queonda", "es": "¿Qué onda?", "pt": "E aí? / Como tá?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "icu3-p03", "promptPt": "Diga 'e aí?', ¿qué onda?. Fale agora.", "audioKey": "cu-queonda", "es": "¿Qué onda?", "pt": "E aí?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n05", "pt": "'Bárbaro' é 'ótimo, demais' — você já ouviu:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-barbaro", "es": "¡Bárbaro!", "pt": "Ótimo! / Demais!" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "icu3-p04", "promptPt": "Reaja 'ótimo!', ¡bárbaro!. Fale agora.", "audioKey": "cu-barbaro", "es": "¡Bárbaro!", "pt": "Ótimo!" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n06", "pt": "'Posta' é 'sério, de verdade':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-posta", "es": "Está muy bueno, posta.", "pt": "Está muito bom, sério." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "icu3-p05", "promptPt": "Confirme 'sério/de verdade', posta. Fale agora.", "audioKey": "cu-posta", "es": "Está muy bueno, posta.", "pt": "Está muito bom, sério." },

    { "tipo": "intro", "voz": "Eduardo", "audioKey": "icu3-n07", "pt": "Um aviso de gíria: 'boludo' entre amigos é 'cara, mano' — afetuoso. Mas com estranho, ou no tom errado, é xingamento. No começo, melhor evitar — só reconheça quando ouvir." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-boludo", "es": "¿Todo bien, boludo?", "pt": "Tudo bem, cara? (entre amigos)" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n08", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "icu3-p06", "promptPt": "Chame alguém: 'che, ¿cómo andás?'. Fale agora.", "audioKey": "cu-che", "es": "Che, ¿cómo andás?", "pt": "Ô, como vai?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "icu3-p07", "promptPt": "Diga 'e aí?', ¿qué onda?. Fale agora.", "audioKey": "cu-queonda", "es": "¿Qué onda?", "pt": "E aí?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "cu-che", "es": "Che, ¿cómo andás?", "pt": "Ô, como vai?" },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "cu-barbaro", "es": "¡Bárbaro!", "pt": "Ótimo!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-r00", "pt": "Pra fechar o Intermediário, uma conversa cheia de cultura. Você entende tudo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-che", "es": "Che, ¿qué onda?", "pt": "Ô, e aí?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-queresmate", "es": "¿Querés un mate?", "pt": "Quer um mate?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-asado", "es": "Hacemos un asado.", "pt": "Vamos fazer um churrasco." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-barbaro", "es": "¡Bárbaro!", "pt": "Ótimo!" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "fu-dale", "es": "¡Dale!", "pt": "Combinado!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n09", "pt": "Cultura em foco: 'che' (ei), '¿qué onda?' (e aí?), 'bárbaro/genial' (ótimo), 'posta' (sério) e 'dale' (beleza) são o tempero rioplatense. Use com leveza — vão te aproximar das pessoas. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "cu-queonda", "es": "¿Qué onda?", "pt": "E aí?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "cu-barbaro", "es": "¡Bárbaro!", "pt": "Ótimo!" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "icu3-n10", "pt": "Essas gírias te fazem soar local. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "icu3-rend", "pt": "Parabéns! Você fechou o módulo Intermediário inteiro — passado, futuro, saúde, serviços, vida social e cultura. Que evolução! No Avançado, a gente lapida. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
