{
  "id": "b06c",
  "nivel": "basico",
  "numero": 6,
  "parte": "3C",
  "titulo": "De compras — Preço, pagar e trocar",
  "subtitulo": "Quanto custa, desconto, parcelar, trocar e devolver",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n01", "pt": "Última parte das compras: preço, pagar e trocar. Antes, recordando: como você diz 'vou levar'? Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p01", "promptPt": "Diga 'vou levar'. Fale agora.", "audioKey": "c-mellevo", "es": "Me lo llevo.", "pt": "Vou levar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n02", "pt": "Escute o fim da compra:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-d7", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-d8", "es": "Mil pesos. ¿Cómo va a pagar?", "pt": "Mil pesos. Como vai pagar?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-d9", "es": "¿Puedo pagar en cuotas?", "pt": "Posso pagar parcelado?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n03", "pt": "Pra perguntar o preço, no Rio da Prata tem um jeito bem comum:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-cuantosale", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p02", "promptPt": "Pergunte o preço. Fale agora.", "audioKey": "c-cuantosale", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n04", "pt": "Pra comentar o preço: caro ou barato:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-caro", "es": "Es muy caro.", "pt": "É muito caro." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-barato", "es": "Es barato.", "pt": "É barato." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep6c-p03", "promptPt": "Diga 'é muito caro'. Fale agora.", "audioKey": "c-caro", "es": "Es muy caro.", "pt": "É muito caro." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n05", "pt": "Pra pedir desconto:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-descuento", "es": "¿Me hace un descuento?", "pt": "Você me dá um desconto?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p04", "promptPt": "Peça um desconto. Fale agora.", "audioKey": "c-descuento", "es": "¿Me hace un descuento?", "pt": "Você me dá um desconto?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n06", "pt": "Pra pagar com cartão — você já viu no restaurante:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r-tarjeta", "es": "¿Puedo pagar con tarjeta?", "pt": "Posso pagar com cartão?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p05", "promptPt": "Pergunte se pode pagar com cartão. Fale agora.", "audioKey": "r-tarjeta", "es": "¿Puedo pagar con tarjeta?", "pt": "Posso pagar com cartão?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n07", "pt": "Na Argentina é super comum parcelar:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-cuotas", "es": "¿Puedo pagar en cuotas?", "pt": "Posso pagar parcelado?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p06", "promptPt": "Pergunte se pode parcelar. Fale agora.", "audioKey": "c-cuotas", "es": "¿Puedo pagar en cuotas?", "pt": "Posso pagar parcelado?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n08", "pt": "Pra pedir o recibo:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "c-ticket", "es": "¿Me da el ticket?", "pt": "Você me dá o recibo?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep6c-p07", "promptPt": "Peça o recibo. Fale agora.", "audioKey": "c-ticket", "es": "¿Me da el ticket?", "pt": "Você me dá o recibo?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n09", "pt": "E se precisar trocar depois:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-cambiar", "es": "Quiero cambiar esto.", "pt": "Quero trocar isto." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p08", "promptPt": "Diga 'quero trocar isto'. Fale agora.", "audioKey": "c-cambiar", "es": "Quiero cambiar esto.", "pt": "Quero trocar isto." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n10", "pt": "Ou devolver:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-devolver", "es": "¿Puedo devolverlo?", "pt": "Posso devolver?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p09", "promptPt": "Pergunte 'posso devolver?'. Fale agora.", "audioKey": "c-devolver", "es": "¿Puedo devolverlo?", "pt": "Posso devolver?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n11", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p10", "promptPt": "Pergunte o preço. Fale agora.", "audioKey": "c-cuantosale", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p11", "promptPt": "Peça um desconto. Fale agora.", "audioKey": "c-descuento", "es": "¿Me hace un descuento?", "pt": "Você me dá um desconto?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep6c-p12", "promptPt": "Diga 'quero trocar isto'. Fale agora.", "audioKey": "c-cambiar", "es": "Quiero cambiar esto.", "pt": "Quero trocar isto." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "c-cuantosale", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "c-descuento", "es": "¿Me hace un descuento?", "pt": "Você me dá um desconto?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-r00", "pt": "Pra fechar, uma cena de compra completa. Você entende tudo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-buscando", "es": "Estoy buscando una remera.", "pt": "Estou procurando uma camiseta." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-probar", "es": "¿Puedo probármelo?", "pt": "Posso provar?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-quedabien", "es": "Me queda bien.", "pt": "Ficou bom." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-cuantosale", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-cuotas", "es": "¿Puedo pagar en cuotas?", "pt": "Posso pagar parcelado?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-mellevo", "es": "Me lo llevo.", "pt": "Vou levar." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n12", "pt": "Gramática em foco: tem dois jeitos de perguntar o preço, e uma forma de dizer 'parcelado' — pergunte sempre, é comum por lá. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-cuantosale", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-cuotas", "es": "¿Puedo pagar en cuotas?", "pt": "Posso pagar parcelado?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep6c-n13", "pt": "Um jeito pergunta o preço; o outro, se dá pra parcelar. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep6c-rend", "pt": "Parabéns! Você fecha uma compra inteira: procurar, provar e pagar. Na sequência, o hotel. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Preço, parcelar e trocar",
    "secoes": [
      {
        "titulo": "Perguntar o preço",
        "corpo": "'¿Cuánto cuesta?' e '¿Cuánto sale?' (mais rioplatense) significam a mesma coisa: quanto custa.",
        "exemplos": [
          { "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
          { "es": "Es muy caro. / Es barato.", "pt": "É muito caro. / É barato." }
        ]
      },
      {
        "titulo": "Pagar e parcelar",
        "corpo": "Na Argentina, parcelar ('en cuotas') é muito comum — vale sempre perguntar. 'Sin interés' = sem juros.",
        "exemplos": [
          { "es": "¿Puedo pagar en cuotas?", "pt": "Posso pagar parcelado?" },
          { "es": "¿Me hace un descuento?", "pt": "Me dá um desconto?" }
        ]
      },
      {
        "titulo": "Trocar e devolver",
        "corpo": "cambiar = trocar; devolver = devolver. Guarde o ticket (recibo).",
        "exemplos": [
          { "es": "Quiero cambiar esto.", "pt": "Quero trocar isto." },
          { "es": "¿Puedo devolverlo?", "pt": "Posso devolver?" }
        ]
      }
    ]
  }
}
