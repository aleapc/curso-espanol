{
  "id": "a04b",
  "nivel": "avancado",
  "numero": 20,
  "parte": "B",
  "titulo": "Modismos — Intensificar e reagir",
  "subtitulo": "Me re gusta, buenísimo, ¡no puede ser!",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n01", "pt": "Parte 2: dar ênfase e reagir na hora, do jeito rioplatense. Antes, recordando: diga 'tá ótimo, eu adoro'. Responda." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "amd2-p01", "promptPt": "Diga 'tá ótimo, eu adoro'. Fale agora.", "audioKey": "md-barbaro", "es": "Está bárbaro, me encanta.", "pt": "Tá ótimo, eu adoro." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n02", "pt": "Escute a reação a uma novidade:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "md-d3", "es": "Me saqué la lotería. — ¡No puede ser!", "pt": "Ganhei na loteria. — Não pode ser!" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "md-d4", "es": "¡Qué bueno! Me re alegro.", "pt": "Que bom! Fico muito feliz." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n03", "pt": "O intensificador rioplatense por excelência vem antes do verbo e quer dizer 'muito'. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "md-regusta", "es": "Me re gusta este lugar.", "pt": "Eu curto muito este lugar." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "amd2-p02", "promptPt": "Diga 'eu curto muito este lugar'. Fale agora.", "audioKey": "md-regusta", "es": "Me re gusta este lugar.", "pt": "Eu curto muito este lugar." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n04", "pt": "Pra dizer 'ótimo' com o superlativo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "md-buenisimo", "es": "El asado estaba buenísimo.", "pt": "O churrasco estava delicioso." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "amd2-p03", "promptPt": "Diga 'o churrasco estava delicioso'. Fale agora.", "audioKey": "md-buenisimo", "es": "El asado estaba buenísimo.", "pt": "O churrasco estava delicioso." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n05", "pt": "Pra reagir com espanto:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "md-nopuedeser", "es": "¡No puede ser!", "pt": "Não pode ser! / Não acredito!" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "amd2-p04", "promptPt": "Reaja: 'não pode ser!'. Fale agora.", "audioKey": "md-nopuedeser", "es": "¡No puede ser!", "pt": "Não pode ser!" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n06", "pt": "Pra elogiar com emoção:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "md-quelindo", "es": "¡Qué lindo quedó!", "pt": "Que lindo ficou!" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "amd2-p05", "promptPt": "Diga 'que lindo ficou!'. Fale agora.", "audioKey": "md-quelindo", "es": "¡Qué lindo quedó!", "pt": "Que lindo ficou!" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n07", "pt": "E pra concordar enfático:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "md-talcual", "es": "Tal cual, pensé lo mismo.", "pt": "Exatamente, pensei o mesmo." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "amd2-p06", "promptPt": "Concorde: 'exatamente, pensei o mesmo'. Fale agora.", "audioKey": "md-talcual", "es": "Tal cual, pensé lo mismo.", "pt": "Exatamente, pensei o mesmo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n08", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "amd2-p07", "promptPt": "Diga 'eu curto muito este lugar'. Fale agora.", "audioKey": "md-regusta", "es": "Me re gusta este lugar.", "pt": "Eu curto muito este lugar." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "amd2-p08", "promptPt": "Reaja: 'não pode ser!'. Fale agora.", "audioKey": "md-nopuedeser", "es": "¡No puede ser!", "pt": "Não pode ser!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "md-regusta", "es": "Me re gusta este lugar.", "pt": "Eu curto muito este lugar." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "md-buenisimo", "es": "El asado estaba buenísimo.", "pt": "O churrasco estava delicioso." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n09", "pt": "Gramática em foco: pra intensificar, três caminhos. O primeiro é um intensificador antes do verbo ou adjetivo, que equivale a 'muito'. O segundo é o superlativo, aquele que termina em -íssimo. E o terceiro é exclamar com 'que' mais o adjetivo. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "md-regusta", "es": "Me re gusta.", "pt": "Eu curto muito." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "md-buenisimo", "es": "Estaba buenísimo.", "pt": "Estava delicioso." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "amd2-n10", "pt": "Três caminhos: o intensificador antes do verbo, o superlativo, e a exclamação. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "amd2-rend", "pt": "Muito bem! Suas reações ganharam emoção. Na última parte: o registro formal, pra trato e trabalho. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Intensificadores e reações",
    "secoes": [
      {
        "titulo": "Três formas de exagerar",
        "corpo": "1) 're' rioplatense: me re gusta, está re lindo (muito). 2) Superlativo -ísimo: buenísimo, riquísimo, carísimo. 3) Exclamação qué + adjetivo: ¡qué lindo!, ¡qué rico!",
        "exemplos": [
          { "es": "Está re bueno.", "pt": "Tá muito bom." },
          { "es": "¡Qué caro!", "pt": "Que caro!" }
        ]
      },
      {
        "titulo": "Reagir na hora",
        "corpo": "¡No puede ser! (não acredito); ¡qué bueno! (que bom); tal cual (exatamente); ¡en serio? (sério?); ¡no me digas! (não me diga)."
      }
    ]
  }
}
