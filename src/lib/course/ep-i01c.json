{
  "id": "i01c",
  "nivel": "intermediario",
  "numero": 10,
  "parte": "C",
  "titulo": "Hablar del pasado — Perguntar e reagir",
  "subtitulo": "Puxar conversa sobre o que a pessoa fez",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n01", "pt": "Última parte: perguntar sobre o passado e reagir. Antes, recordando: diga 'fomos à praia'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipc1-p01", "promptPt": "Diga 'fomos à praia'. Fale agora.", "audioKey": "pa-fuimos", "es": "Fuimos a la playa.", "pt": "Fomos à praia." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n02", "pt": "Escute uma conversa de segunda-feira:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-d5", "es": "¿Adónde fuiste el finde?", "pt": "Aonde você foi no fim de semana?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-d6", "es": "Fui a Colonia. ¡Estuvo bárbaro!", "pt": "Fui a Colônia. Foi ótimo!" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n03", "pt": "Pra perguntar aonde a pessoa foi:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-adonde", "es": "¿Adónde fuiste?", "pt": "Aonde você foi?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ipc1-p02", "promptPt": "Pergunte 'aonde você foi?'. Fale agora.", "audioKey": "pa-adonde", "es": "¿Adónde fuiste?", "pt": "Aonde você foi?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n04", "pt": "Pra perguntar como foi:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-comoestuvo", "es": "¿Cómo estuvo?", "pt": "Como foi?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ipc1-p03", "promptPt": "Pergunte 'como foi?'. Fale agora.", "audioKey": "pa-comoestuvo", "es": "¿Cómo estuvo?", "pt": "Como foi?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n05", "pt": "Pra reagir que foi ótimo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-estuvobarbaro", "es": "Estuvo bárbaro.", "pt": "Foi ótimo." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipc1-p04", "promptPt": "Diga 'foi ótimo'. Fale agora.", "audioKey": "pa-estuvobarbaro", "es": "Estuvo bárbaro.", "pt": "Foi ótimo." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n06", "pt": "Pra dizer que adorou:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-encanto", "es": "Me encantó.", "pt": "Adorei." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ipc1-p05", "promptPt": "Diga 'adorei'. Fale agora.", "audioKey": "pa-encanto", "es": "Me encantó.", "pt": "Adorei." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n07", "pt": "Pra perguntar se a pessoa gostou:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-tegusto", "es": "¿Te gustó?", "pt": "Você gostou?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipc1-p06", "promptPt": "Pergunte 'você gostou?'. Fale agora.", "audioKey": "pa-tegusto", "es": "¿Te gustó?", "pt": "Você gostou?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n08", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ipc1-p07", "promptPt": "Pergunte 'aonde você foi?'. Fale agora.", "audioKey": "pa-adonde", "es": "¿Adónde fuiste?", "pt": "Aonde você foi?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipc1-p08", "promptPt": "Diga 'foi ótimo'. Fale agora.", "audioKey": "pa-estuvobarbaro", "es": "Estuvo bárbaro.", "pt": "Foi ótimo." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "pa-comoestuvo", "es": "¿Cómo estuvo?", "pt": "Como foi?" },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "pa-encanto", "es": "Me encantó.", "pt": "Adorei." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-r00", "pt": "Pra fechar, uma conversa sobre o fim de semana. Você entende tudo:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-adonde", "es": "¿Adónde fuiste?", "pt": "Aonde você foi?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-fui", "es": "Ayer fui al centro.", "pt": "Ontem fui ao centro." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-comoestuvo", "es": "¿Cómo estuvo?", "pt": "Como foi?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-estuvobarbaro", "es": "Estuvo bárbaro.", "pt": "Foi ótimo." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-encanto", "es": "Me encantó.", "pt": "Adorei." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n09", "pt": "Gramática em foco: pra reagir ao passado, há expressões prontas pra dizer 'foi ótimo', 'adorei' e 'gostei'. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-estuvobarbaro", "es": "Estuvo bárbaro.", "pt": "Foi ótimo." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-encanto", "es": "Me encantó.", "pt": "Adorei." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipc1-n10", "pt": "São as reações que dão vida ao relato. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ipc1-rend", "pt": "Parabéns! Você pergunta e conta o passado. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Perguntar e reagir ao passado",
    "secoes": [
      {
        "titulo": "Perguntar",
        "corpo": "¿Qué hiciste? (o que fez?), ¿adónde fuiste? (aonde foi?), ¿cómo estuvo? (como foi?), ¿te gustó? (gostou?).",
        "exemplos": [
          { "es": "¿Adónde fuiste el finde?", "pt": "Aonde você foi no fim de semana? ('el finde' = o fds)" }
        ]
      },
      {
        "titulo": "Reagir",
        "corpo": "Estuvo bárbaro/genial (foi ótimo), me encantó (adorei), me gustó (gostei), estuvo más o menos (foi mais ou menos).",
        "exemplos": [
          { "es": "Me encantó, estuvo bárbaro.", "pt": "Adorei, foi ótimo." }
        ]
      }
    ]
  }
}
