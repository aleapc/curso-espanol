{
  "id": "i01a",
  "nivel": "intermediario",
  "numero": 10,
  "parte": "A",
  "titulo": "Hablar del pasado — O que eu fiz",
  "subtitulo": "O pretérito: contar o que aconteceu",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n01", "pt": "Bem-vindo ao Intermediário! Agora você começa a contar histórias. Episódio 1: falar do passado, o que você fez. Fale em voz alta quando eu pedir." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n02", "pt": "Recordando do Básico: responda 'muito bem, obrigado'." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ipa1-p01", "promptPt": "Responda 'muito bem, obrigado'. Fale agora.", "audioKey": "es-mb", "es": "Muy bien, gracias.", "pt": "Muito bem, obrigado." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n03", "pt": "Escute alguém contando o dia:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-d1", "es": "¿Qué hiciste ayer?", "pt": "O que você fez ontem?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-d2", "es": "Fui al centro y comí afuera.", "pt": "Fui ao centro e comi fora." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n04", "pt": "Pra perguntar o que a pessoa fez ontem:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-hiciste", "es": "¿Qué hiciste ayer?", "pt": "O que você fez ontem?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ipa1-p02", "promptPt": "Pergunte 'o que você fez ontem?'. Fale agora.", "audioKey": "pa-hiciste", "es": "¿Qué hiciste ayer?", "pt": "O que você fez ontem?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n05", "pt": "Pra dizer aonde você foi:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-fui", "es": "Ayer fui al centro.", "pt": "Ontem fui ao centro." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipa1-p03", "promptPt": "Diga 'ontem fui ao centro'. Fale agora.", "audioKey": "pa-fui", "es": "Ayer fui al centro.", "pt": "Ontem fui ao centro." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n06", "pt": "Pra dizer que comeu:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-comi", "es": "Comí en un restaurante.", "pt": "Comi num restaurante." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipa1-p04", "promptPt": "Diga 'comi num restaurante'. Fale agora.", "audioKey": "pa-comi", "es": "Comí en un restaurante.", "pt": "Comi num restaurante." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n07", "pt": "Pra dizer que caminhou muito:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-camine", "es": "Caminé mucho.", "pt": "Caminhei muito." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipa1-p05", "promptPt": "Diga 'caminhei muito'. Fale agora.", "audioKey": "pa-camine", "es": "Caminé mucho.", "pt": "Caminhei muito." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n08", "pt": "Pra dizer que comprou um presente:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "pa-compre", "es": "Compré un regalo.", "pt": "Comprei um presente." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ipa1-p06", "promptPt": "Diga 'comprei um presente'. Fale agora.", "audioKey": "pa-compre", "es": "Compré un regalo.", "pt": "Comprei um presente." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n09", "pt": "Pra dizer que visitou um museu:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-visite", "es": "Visité un museo.", "pt": "Visitei um museu." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipa1-p07", "promptPt": "Diga 'visitei um museu'. Fale agora.", "audioKey": "pa-visite", "es": "Visité un museo.", "pt": "Visitei um museu." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n10", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipa1-p08", "promptPt": "Diga 'ontem fui ao centro'. Fale agora.", "audioKey": "pa-fui", "es": "Ayer fui al centro.", "pt": "Ontem fui ao centro." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ipa1-p09", "promptPt": "Diga 'comi num restaurante'. Fale agora.", "audioKey": "pa-comi", "es": "Comí en un restaurante.", "pt": "Comi num restaurante." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "pa-fui", "es": "Ayer fui al centro.", "pt": "Ontem fui ao centro." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "pa-comi", "es": "Comí en un restaurante.", "pt": "Comi num restaurante." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n11", "pt": "Gramática em foco: o pretérito, o passado. Os verbos terminados em -ar mudam a terminação; os terminados em -er e -ir mudam de outro jeito. E o verbo 'ir' é irregular. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-camine", "es": "Caminé.", "pt": "Caminhei. (-ar → -é)" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-comi", "es": "Comí.", "pt": "Comi. (-er/-ir → -í)" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "pa-fui", "es": "Fui.", "pt": "Fui. (irregular)" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ipa1-n12", "pt": "Cada grupo de verbos tem sua terminação no passado, e 'ir' é o irregular mais usado. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ipa1-rend", "pt": "Muito bem! Você já conta o que fez. Na próxima: contar uma viagem. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
  "aprofundar": {
    "titulo": "O pretérito (passado simples)",
    "secoes": [
      {
        "titulo": "Regulares (eu)",
        "corpo": "Verbos -ar: tira -ar, põe -é (hablé, caminé, compré). Verbos -er/-ir: tira a terminação, põe -í (comí, salí, viví).",
        "exemplos": [
          { "es": "Ayer hablé con ella.", "pt": "Ontem falei com ela." },
          { "es": "Comí muy bien.", "pt": "Comi muito bem." }
        ]
      },
      {
        "titulo": "Irregulares úteis",
        "corpo": "ir/ser → fui; hacer → hice; estar → estuve; tener → tuve. 'Fui' serve pra 'fui' (ir) e 'fui' (ser).",
        "exemplos": [
          { "es": "Fui al museo e hice una visita.", "pt": "Fui ao museu e fiz uma visita." }
        ]
      },
      {
        "titulo": "Perguntar (vos/tú)",
        "corpo": "¿Qué hiciste? (o que você fez?), ¿adónde fuiste? (aonde você foi?)."
      }
    ]
  }
}
