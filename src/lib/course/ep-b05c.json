{
  "id": "b05c",
  "nivel": "basico",
  "numero": 5,
  "parte": "2C",
  "titulo": "Comida a fundo — Sobremesa, café e restrições",
  "subtitulo": "Postres, café e como avisar alergias e restrições",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n01", "pt": "Última parte do restaurante: sobremesa, café e — muito importante — restrições alimentares. Antes, recordando: como se diz 'sem cebola'? Responda." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep5c-p01", "promptPt": "Diga 'sem cebola'. Fale agora.", "audioKey": "r2-sincebolla", "es": "Sin cebolla.", "pt": "Sem cebola." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n02", "pt": "Escute o casal pedindo a sobremesa:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-d5", "es": "¿Van a querer postre?", "pt": "Vão querer sobremesa?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-d6", "es": "Sí, un flan con dulce de leche.", "pt": "Sim, um pudim com doce de leite." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n03", "pt": "Sobremesa é 'postre'. Pra pedir, 'de sobremesa…':" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-depostre", "es": "De postre, un flan.", "pt": "De sobremesa, um pudim." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep5c-p02", "promptPt": "Peça um pudim de sobremesa. Fale agora.", "audioKey": "r2-depostre", "es": "De postre, un flan.", "pt": "De sobremesa, um pudim." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n04", "pt": "O doce símbolo da região, o doce de leite:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-dulce", "es": "Con dulce de leche.", "pt": "Com doce de leite." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep5c-p03", "promptPt": "Peça 'com doce de leite'. Fale agora.", "audioKey": "r2-dulce", "es": "Con dulce de leche.", "pt": "Com doce de leite." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n05", "pt": "Sorvete é 'helado':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-helado", "es": "Un helado.", "pt": "Um sorvete." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep5c-p04", "promptPt": "Peça um sorvete. Fale agora.", "audioKey": "r2-helado", "es": "Un helado.", "pt": "Um sorvete." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n06", "pt": "O café: simples é 'un café'; com bastante leite, 'café con leche'; e o cortado, com um pingo de leite:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-cortado", "es": "Un cortado.", "pt": "Um café cortado (com pouco leite)." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-conleche", "es": "Un café con leche.", "pt": "Um café com leite." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep5c-p05", "promptPt": "Peça um café com leite. Fale agora.", "audioKey": "r2-conleche", "es": "Un café con leche.", "pt": "Um café com leite." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n07", "pt": "Agora o essencial pra segurança: as restrições. Pra dizer que é vegetariano ou vegetariana:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-vegetariano", "es": "Soy vegetariano.", "pt": "Sou vegetariano." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-vegetariana", "es": "Soy vegetariana.", "pt": "Sou vegetariana." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep5c-p06", "promptPt": "Diga que você é vegetariano ou vegetariana. Fale agora.", "audioKey": "r2-vegetariana", "es": "Soy vegetariana.", "pt": "Sou vegetariana." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n08", "pt": "Pra dizer que não come algo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-nocomo", "es": "No como carne.", "pt": "Não como carne." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep5c-p07", "promptPt": "Diga 'não como carne'. Fale agora.", "audioKey": "r2-nocomo", "es": "No como carne.", "pt": "Não como carne." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n09", "pt": "Pra avisar de alergia — pode ser vital:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-alergico", "es": "Soy alérgico al maní.", "pt": "Sou alérgico a amendoim." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-alergica", "es": "Soy alérgica a los mariscos.", "pt": "Sou alérgica a frutos do mar." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep5c-p08", "promptPt": "Avise uma alergia sua: 'sou alérgico a…'. Fale agora.", "audioKey": "r2-alergico", "es": "Soy alérgico al maní.", "pt": "Sou alérgico a amendoim." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n10", "pt": "Pra perguntar se um prato leva certo ingrediente:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-lleva", "es": "¿Lleva gluten?", "pt": "Leva glúten?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep5c-p09", "promptPt": "Pergunte se leva glúten. Fale agora.", "audioKey": "r2-lleva", "es": "¿Lleva gluten?", "pt": "Leva glúten?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n11", "pt": "E pra pedir sem glúten:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-singluten", "es": "Sin gluten, por favor.", "pt": "Sem glúten, por favor." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep5c-p10", "promptPt": "Peça 'sem glúten, por favor'. Fale agora.", "audioKey": "r2-singluten", "es": "Sin gluten, por favor.", "pt": "Sem glúten, por favor." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n12", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep5c-p11", "promptPt": "Peça um café com leite. Fale agora.", "audioKey": "r2-conleche", "es": "Un café con leche.", "pt": "Um café com leite." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep5c-p12", "promptPt": "Avise uma alergia: 'sou alérgico a…'. Fale agora.", "audioKey": "r2-alergico", "es": "Soy alérgico al maní.", "pt": "Sou alérgico a amendoim." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep5c-p13", "promptPt": "Pergunte se leva glúten. Fale agora.", "audioKey": "r2-lleva", "es": "¿Lleva gluten?", "pt": "Leva glúten?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "r2-singluten", "es": "Sin gluten, por favor.", "pt": "Sem glúten, por favor." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "r2-nocomo", "es": "No como carne.", "pt": "Não como carne." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-r00", "pt": "Pra fechar, uma cena de sobremesa e conta. Você entende tudo:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-d5", "es": "¿Van a querer postre?", "pt": "Vão querer sobremesa?" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-depostre", "es": "De postre, un flan.", "pt": "De sobremesa, um pudim." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-dulce", "es": "Con dulce de leche.", "pt": "Com doce de leite." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-conleche", "es": "Un café con leche.", "pt": "Um café com leite." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r-cuenta", "es": "La cuenta, por favor.", "pt": "A conta, por favor." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n13", "pt": "Gramática em foco: negar e restringir. 'No como…' é não como; 'sin…' é sem; 'soy alérgico a…' é sou alérgico a. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "r2-nocomo", "es": "No como carne.", "pt": "Não como carne." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "r2-singluten", "es": "Sin gluten.", "pt": "Sem glúten." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep5c-n14", "pt": "Essas frases protegem você na mesa. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep5c-rend", "pt": "Parabéns! Você fechou o restaurante inteiro: chegar, pedir, comer de tudo e pagar. Na sequência, vamos às compras. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Restrições alimentares (negar e avisar)",
    "secoes": [
      {
        "titulo": "Dizer o que você é / não come",
        "corpo": "Use 'soy' pra identidade alimentar e 'no como' pra o que evita.",
        "exemplos": [
          { "es": "Soy vegetariano. / Soy vegetariana.", "pt": "Sou vegetariano. / Sou vegetariana." },
          { "es": "No como carne.", "pt": "Não como carne." }
        ]
      },
      {
        "titulo": "Alergias (importante!)",
        "corpo": "'Soy alérgico/a a…'. Concorda com homem (alérgico) ou mulher (alérgica). 'Maní' é amendoim.",
        "exemplos": [
          { "es": "Soy alérgico al maní.", "pt": "Sou alérgico a amendoim." },
          { "es": "Soy alérgica a los mariscos.", "pt": "Sou alérgica a frutos do mar." }
        ]
      },
      {
        "titulo": "Perguntar e pedir sem",
        "corpo": "'¿Lleva…?' pergunta se um prato contém algo; 'sin…' pede sem aquilo.",
        "exemplos": [
          { "es": "¿Lleva gluten?", "pt": "Leva glúten?" },
          { "es": "Sin gluten, por favor.", "pt": "Sem glúten, por favor." }
        ]
      }
    ]
  }
}
