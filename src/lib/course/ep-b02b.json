{
  "id": "b02b",
  "nivel": "basico",
  "numero": 2,
  "parte": "B",
  "titulo": "Números — Dezenas, centenas e preços",
  "subtitulo": "Contar até mil e lidar com dinheiro",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n01", "pt": "Parte 2: dezenas, centenas e preços. Antes, recordando: diga 'dez'. Responda." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2b-p01", "promptPt": "Diga 'dez', diez. Fale agora.", "audioKey": "n-diez", "es": "Diez.", "pt": "Dez." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n02", "pt": "As dezenas. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-dezenas", "es": "Veinte, treinta, cuarenta, cincuenta.", "pt": "Vinte, trinta, quarenta, cinquenta." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-dezenas2", "es": "Sesenta, setenta, ochenta, noventa, cien.", "pt": "Sessenta, setenta, oitenta, noventa, cem." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n03", "pt": "Treine 'trinta', treinta:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-treinta", "es": "Treinta.", "pt": "Trinta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2b-p02", "promptPt": "Diga 'trinta', treinta. Fale agora.", "audioKey": "n-treinta", "es": "Treinta.", "pt": "Trinta." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n04", "pt": "'Cinquenta', cincuenta:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-cincuenta", "es": "Cincuenta.", "pt": "Cinquenta." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2b-p03", "promptPt": "Diga 'cinquenta', cincuenta. Fale agora.", "audioKey": "n-cincuenta", "es": "Cincuenta.", "pt": "Cinquenta." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n05", "pt": "Pra combinar, use 'y' (e): trinta e cinco é 'treinta y cinco'. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-35", "es": "Treinta y cinco.", "pt": "Trinta e cinco." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep2b-p04", "promptPt": "Diga 'trinta e cinco', treinta y cinco. Fale agora.", "audioKey": "n-35", "es": "Treinta y cinco.", "pt": "Trinta e cinco." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n06", "pt": "Cem é 'cien'. Duzentos e quinhentos:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-cien", "es": "Cien.", "pt": "Cem." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-cientos", "es": "Doscientos, quinientos.", "pt": "Duzentos, quinhentos." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep2b-p05", "promptPt": "Diga 'cem', cien. Fale agora.", "audioKey": "n-cien", "es": "Cien.", "pt": "Cem." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n07", "pt": "Mil é 'mil':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-mil", "es": "Mil.", "pt": "Mil." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2b-p06", "promptPt": "Diga 'mil'. Fale agora.", "audioKey": "n-mil", "es": "Mil.", "pt": "Mil." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n08", "pt": "Agora os preços. Escute:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-d1", "es": "Son quinientos pesos.", "pt": "São quinhentos pesos." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n09", "pt": "Pra perguntar quanto é — você já sabe:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "c-cuantosale", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep2b-p07", "promptPt": "Pergunte 'quanto custa?'. Fale agora.", "audioKey": "c-cuantosale", "es": "¿Cuánto sale?", "pt": "Quanto custa?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n10", "pt": "Pra pedir o troco, 'el vuelto':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "n-vuelto", "es": "¿Me da el vuelto?", "pt": "Pode me dar o troco?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2b-p08", "promptPt": "Peça o troco, 'el vuelto'. Fale agora.", "audioKey": "n-vuelto", "es": "¿Me da el vuelto?", "pt": "Pode me dar o troco?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n11", "pt": "Pra saber se tem trocado:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-cambio", "es": "¿Tiene cambio?", "pt": "Tem trocado?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep2b-p09", "promptPt": "Pergunte se tem trocado, 'cambio'. Fale agora.", "audioKey": "n-cambio", "es": "¿Tiene cambio?", "pt": "Tem trocado?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n12", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ep2b-p10", "promptPt": "Diga 'trinta e cinco'. Fale agora.", "audioKey": "n-35", "es": "Treinta y cinco.", "pt": "Trinta e cinco." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ep2b-p11", "promptPt": "Diga 'mil'. Fale agora.", "audioKey": "n-mil", "es": "Mil.", "pt": "Mil." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "n-dezenas", "es": "Veinte, treinta, cuarenta, cincuenta.", "pt": "As dezenas." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "n-35", "es": "Treinta y cinco.", "pt": "Trinta e cinco." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n13", "pt": "Gramática em foco: pra montar números, dezena + 'y' + unidade: cuarenta y dos (42). E cem sozinho é 'cien', mas com mais números vira 'ciento': ciento veinte (120). Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-42", "es": "Cuarenta y dos.", "pt": "Quarenta e dois." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "n-ciento", "es": "Ciento veinte.", "pt": "Cento e vinte." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ep2b-n14", "pt": "'Y' junta dezena e unidade; cien vira ciento. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ep2b-rend", "pt": "Muito bem! Você lida com preços. Na última parte: horas e datas. Até já!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-gracias", "es": "Gracias.", "pt": "Obrigado(a)." }
  ],
  "aprofundar": {
    "titulo": "Dezenas, centenas e dinheiro",
    "secoes": [
      {
        "titulo": "Montar números",
        "corpo": "Dezena + 'y' + unidade: treinta y cinco (35), cuarenta y dos (42). Centenas: cien (100), pero ciento veinte (120); doscientos, quinientos, mil.",
        "exemplos": [
          { "es": "Son quinientos pesos.", "pt": "São quinhentos pesos." }
        ]
      },
      {
        "titulo": "Dinheiro",
        "corpo": "el vuelto = o troco; '¿tiene cambio?' = tem trocado?; en efectivo = em dinheiro."
      }
    ]
  }
}
