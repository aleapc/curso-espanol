          { "es": "oficina", "pt": "escritório (mecânica = taller)" },
          { "es": "apellido", "pt": "sobrenome (não apelido)" },
          { "es": "cena", "pt": "jantar (não cena de filme)" }
        ]
      }
    ]
  }
}
