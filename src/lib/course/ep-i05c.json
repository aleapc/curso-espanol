{
  "id": "i05c",
  "nivel": "intermediario",
  "numero": 14,
  "parte": "C",
  "titulo": "Servicios — Reclamar e resolver",
  "subtitulo": "Quando algo dá errado: reclamar com educação",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n01", "pt": "Última parte: reclamar e resolver problemas. Antes, recordando: diga 'preciso de um chip'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ise3-p01", "promptPt": "Diga 'preciso de um chip'. Fale agora.", "audioKey": "se-chip", "es": "Necesito un chip.", "pt": "Preciso de um chip." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n02", "pt": "Escute uma reclamação:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "se-d5", "es": "Tengo un problema con la habitación.", "pt": "Tenho um problema com o quarto." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "se-d6", "es": "Quiero hacer un reclamo.", "pt": "Quero fazer uma reclamação." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n03", "pt": "Pra abrir o assunto, dizendo que você tem um problema:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "se-problema", "es": "Tengo un problema.", "pt": "Tenho um problema." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ise3-p02", "promptPt": "Diga 'tenho um problema'. Fale agora.", "audioKey": "se-problema", "es": "Tengo un problema.", "pt": "Tenho um problema." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n04", "pt": "Pra fazer uma reclamação formal:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "se-reclamo", "es": "Quiero hacer un reclamo.", "pt": "Quero fazer uma reclamação." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ise3-p03", "promptPt": "Diga 'quero fazer uma reclamação'. Fale agora.", "audioKey": "se-reclamo", "es": "Quiero hacer un reclamo.", "pt": "Quero fazer uma reclamação." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n05", "pt": "Pra falar com a pessoa certa:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "se-conquien", "es": "¿Con quién puedo hablar?", "pt": "Com quem posso falar?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ise3-p04", "promptPt": "Pergunte 'com quem posso falar?'. Fale agora.", "audioKey": "se-conquien", "es": "¿Con quién puedo hablar?", "pt": "Com quem posso falar?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n06", "pt": "Pra apontar o que está quebrado:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "se-nofunciona", "es": "Esto no funciona.", "pt": "Isto não funciona." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ise3-p05", "promptPt": "Diga 'isto não funciona'. Fale agora.", "audioKey": "se-nofunciona", "es": "Esto no funciona.", "pt": "Isto não funciona." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n07", "pt": "E pra pedir ajuda (você já sabe):" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "tr-ayudar", "es": "¿Me puede ayudar?", "pt": "Pode me ajudar?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ise3-p06", "promptPt": "Peça ajuda. Fale agora.", "audioKey": "tr-ayudar", "es": "¿Me puede ayudar?", "pt": "Pode me ajudar?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n08", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "ise3-p07", "promptPt": "Diga 'tenho um problema'. Fale agora.", "audioKey": "se-problema", "es": "Tengo un problema.", "pt": "Tenho um problema." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "ise3-p08", "promptPt": "Diga 'quero fazer uma reclamação'. Fale agora.", "audioKey": "se-reclamo", "es": "Quiero hacer un reclamo.", "pt": "Quero fazer uma reclamação." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "se-problema", "es": "Tengo un problema.", "pt": "Tenho um problema." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "se-reclamo", "es": "Quiero hacer un reclamo.", "pt": "Quero fazer uma reclamação." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-r00", "pt": "Pra fechar, resolver um problema do começo ao fim. Você entende tudo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "se-problema", "es": "Tengo un problema.", "pt": "Tenho um problema." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "se-nofunciona", "es": "Esto no funciona.", "pt": "Isto não funciona." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "se-conquien", "es": "¿Con quién puedo hablar?", "pt": "Com quem posso falar?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "se-reclamo", "es": "Quiero hacer un reclamo.", "pt": "Quero fazer uma reclamação." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "tr-ayudar", "es": "¿Me puede ayudar?", "pt": "Pode me ajudar?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n09", "pt": "Gramática em foco: pra reclamar com educação, comece com o fato (tenho um problema, isto não funciona) e peça uma saída (com quem posso falar, quero fazer uma reclamação). Tom calmo resolve mais. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "se-problema", "es": "Tengo un problema.", "pt": "Tenho um problema." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "se-reclamo", "es": "Quiero hacer un reclamo.", "pt": "Quero fazer uma reclamação." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "ise3-n10", "pt": "Fato mais pedido de solução, com calma. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "ise3-rend", "pt": "Parabéns! Você resolve serviços e reclama com educação. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Reclamar e resolver",
    "secoes": [
      {
        "titulo": "Estrutura da reclamação",
        "corpo": "1) o fato: 'tengo un problema', 'esto no funciona'. 2) a saída: '¿con quién puedo hablar?', 'quiero hacer un reclamo'. Sempre com 'disculpe' e tom calmo.",
        "exemplos": [
          { "es": "Disculpe, tengo un problema. Quiero hacer un reclamo.", "pt": "Com licença, tenho um problema. Quero fazer uma reclamação." }
        ]
      }
    ]
  }
}
