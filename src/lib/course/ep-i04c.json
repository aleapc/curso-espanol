{
  "id": "i04c",
  "nivel": "intermediario",
  "numero": 13,
  "parte": "C",
  "titulo": "Salud — Resolver e melhorar",
  "subtitulo": "Pequenos acidentes, remédio e melhora",
  "steps": [
    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n01", "pt": "Última parte: resolver pequenos problemas e melhorar. Antes, recordando: diga 'preciso de um médico'. Responda." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "isa3-p01", "promptPt": "Diga 'preciso de um médico'. Fale agora.", "audioKey": "sa-medico", "es": "Necesito un médico.", "pt": "Preciso de um médico." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n02", "pt": "Escute na farmácia:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "sa-d5", "es": "Me corté el dedo.", "pt": "Cortei o dedo." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "sa-d6", "es": "¿Cada cuánto lo tomo?", "pt": "De quanto em quanto tempo tomo?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n03", "pt": "Pra dizer que se cortou:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "sa-corte", "es": "Me corté el dedo.", "pt": "Cortei o dedo." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "isa3-p02", "promptPt": "Diga 'cortei o dedo'. Fale agora.", "audioKey": "sa-corte", "es": "Me corté el dedo.", "pt": "Cortei o dedo." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n04", "pt": "Pra dizer que torceu o tornozelo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "sa-tobillo", "es": "Me torcí el tobillo.", "pt": "Torci o tornozelo." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "isa3-p03", "promptPt": "Diga 'torci o tornozelo'. Fale agora.", "audioKey": "sa-tobillo", "es": "Me torcí el tobillo.", "pt": "Torci o tornozelo." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n05", "pt": "Pra pedir um remédio (você já viu):" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-algodolor", "es": "¿Tienen algo para el dolor?", "pt": "Vocês têm algo pra dor?" },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "isa3-p04", "promptPt": "Peça 'algo pra dor'. Fale agora.", "audioKey": "m-algodolor", "es": "¿Tienen algo para el dolor?", "pt": "Vocês têm algo pra dor?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n06", "pt": "Pra saber de quanto em quanto tempo tomar:" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "sa-cadacuanto", "es": "¿Cada cuánto lo tomo?", "pt": "De quanto em quanto tempo tomo?" },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "isa3-p05", "promptPt": "Pergunte 'de quanto em quanto tomo?'. Fale agora.", "audioKey": "sa-cadacuanto", "es": "¿Cada cuánto lo tomo?", "pt": "De quanto em quanto tempo tomo?" },
    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n07", "pt": "E quando melhorar, pra dizer 'já me sinto melhor':" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "sa-mejor", "es": "Ya me siento mejor.", "pt": "Já me sinto melhor." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "isa3-p06", "promptPt": "Diga 'já me sinto melhor'. Fale agora.", "audioKey": "sa-mejor", "es": "Ya me siento mejor.", "pt": "Já me sinto melhor." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n08", "pt": "Vamos recordar. Responda em voz alta." },
    { "tipo": "responde", "voz": "Diego", "promptAudioKey": "isa3-p07", "promptPt": "Diga 'cortei o dedo'. Fale agora.", "audioKey": "sa-corte", "es": "Me corté el dedo.", "pt": "Cortei o dedo." },
    { "tipo": "responde", "voz": "Ana", "promptAudioKey": "isa3-p08", "promptPt": "Diga 'já me sinto melhor'. Fale agora.", "audioKey": "sa-mejor", "es": "Ya me siento mejor.", "pt": "Já me sinto melhor." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-s00", "pt": "Shadowing: repita junto, sem ler." },
    { "tipo": "shadow", "voz": "Diego", "audioKey": "sa-corte", "es": "Me corté el dedo.", "pt": "Cortei o dedo." },
    { "tipo": "shadow", "voz": "Ana", "audioKey": "sa-cadacuanto", "es": "¿Cada cuánto lo tomo?", "pt": "De quanto em quanto tomo?" },

    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-r00", "pt": "Pra fechar, uma ida ao médico do começo ao fim. Você entende tudo:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "sa-mal", "es": "No me siento bien.", "pt": "Não me sinto bem." },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "sa-fiebre", "es": "Tengo fiebre.", "pt": "Estou com febre." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "sa-medico", "es": "Necesito un médico.", "pt": "Preciso de um médico." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "m-algodolor", "es": "¿Tienen algo para el dolor?", "pt": "Vocês têm algo pra dor?" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "sa-mejor", "es": "Ya me siento mejor.", "pt": "Já me sinto melhor." },

    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n09", "pt": "Gramática em foco: pequenos acidentes vêm com o verbo reflexivo no passado — me cortei, torci, caí. É o pronome reflexivo mais o verbo no pretérito. Escute:" },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "sa-corte", "es": "Me corté el dedo.", "pt": "Cortei o dedo." },
    { "tipo": "ouvir", "voz": "Diego", "audioKey": "sa-tobillo", "es": "Me torcí el tobillo.", "pt": "Torci o tornozelo." },
    { "tipo": "intro", "voz": "Bia", "audioKey": "isa3-n10", "pt": "Me cortei, torci, caí — o acidente reflexivo. Mais em 'Para ir além'." },

    { "tipo": "recap", "voz": "Bia", "audioKey": "isa3-rend", "pt": "Parabéns! Você se vira numa emergência de saúde. Até logo!" },
    { "tipo": "ouvir", "voz": "Ana", "audioKey": "es-chau", "es": "¡Chau!", "pt": "Tchau!" }
  ],
  "aprofundar": {
    "titulo": "Acidentes, remédio e melhora",
    "secoes": [
      {
        "titulo": "Acidentes (reflexivo no passado)",
        "corpo": "me corté (me cortei), me torcí el tobillo (torci o tornozelo), me caí (caí), me quemé (me queimei).",
        "exemplos": [
          { "es": "Me caí y me torcí el tobillo.", "pt": "Caí e torci o tornozelo." }
        ]
      },
      {
        "titulo": "Remédio e melhora",
        "corpo": "¿cada cuánto lo tomo? (de quanto em quanto?), una pastilla (um comprimido), ya me siento mejor (já estou melhor)."
      }
    ]
  }
}
